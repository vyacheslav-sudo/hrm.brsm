Процедура ИсправитьИндексыИнфляции3052() Экспорт
	
	НаборЗаписей = РегистрыСведений.ИндексИнфляции.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Период.Установить(Дата(2023,08,01));
	НаборЗаписей.Прочитать();
	Если НаборЗаписей.Количество() > 0 Тогда
		Запись = НаборЗаписей[0];
		Если Запись.Индекс <> 0.986 тогда
			Запись.Индекс = 0.986;
			НаборЗаписей.Записать();
		КонецЕсли;	
	КонецЕсли	
	
