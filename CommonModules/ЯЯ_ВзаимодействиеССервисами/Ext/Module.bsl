// Предопределенные объекты

// Функция предназначена для получения ссылки на предопределенный объект
//
// Параметры:
//  Параметр - 	 Наименование элемента (Строка или СправочникСсылка.ПредопределенныеОбъекты)
//  Родитель - 	 Родитель
// 
// Возвращаемое значение:
//  Ссылка на предопределенный объект или НЕОПРЕДЕЛЕНО
//
Функция ПолучитьПредопределенныйОбъект(Параметр, Родитель = Неопределено) Экспорт
	
	Если ТипЗнч(Параметр) = Тип("Строка") Тогда
		Наименование = Параметр;
		Ссылка = Справочники.ПредопределенныеОбъекты.НайтиПоНаименованию(Наименование, Истина, Родитель);
	ИначеЕсли ТипЗнч(Параметр) = Тип("СправочникСсылка.ПредопределенныеОбъекты") Тогда
		Наименование = Параметр.Наименование;
		Ссылка = Параметр;
	КонецЕсли;
	
	Если НЕ ЯЯ_ВзаимодействиеССервисами.Выбрано(Ссылка) Тогда
		Сообщить("ВНИМАНИЕ! Не найден предопределенный объект " + Наименование + " - сообщите разработчикам!", СтатусСообщения.Внимание);
	ИначеЕсли НЕ ЯЯ_ВзаимодействиеССервисами.Выбрано(Ссылка.Объект) Тогда
		Сообщить("ВНИМАНИЕ! Не найден предопределенный объект " + Наименование + " - сообщите разработчикам!", СтатусСообщения.Внимание);
	КонецЕсли;
	
	Возврат Ссылка.Объект;
	
КонецФункции

// Функция предназначена для получения значения свойства объекта в общем модуле
//
// Параметры:
//  Объект				 - Объект значения свойств объекта
//  ИмяСвойства			 - Имя свойства объекта
//  ЗначениеПоУмолчанию	 - Значение по-умолчанию объекта
// 
// Возвращаемое значение:
//  Значение свойства объекта 
//
Функция ПолучитьЗначениеСвойства(Объект, ИмяСвойства, ЗначениеПоУмолчанию = Неопределено) Экспорт
	
	Если ЗначениеПоУмолчанию = Неопределено тогда
		ЗначениеПоУмолчанию = Справочники.ЗначенияСвойствОбъектов.ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос("ВЫБРАТЬ Значение ИЗ РегистрСведений.ЗначенияСвойствОбъектов ГДЕ Свойство.Наименование=&ИмяСвойства И Объект=&Объект");
	Запрос.УстановитьПараметр("Объект", Объект);
	Запрос.УстановитьПараметр("ИмяСвойства", ИмяСвойства);
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Возврат ?(НЕ Результат.Следующий(), ЗначениеПоУмолчанию, Результат.Значение);
	
КонецФункции

// Функция - аналог использования функции ЗначениеЗаполнено с модификацией
//
// Параметры:
//  Значение			 - Объект проверки
//  ТекстПредупреждения	 - Текст предупреждения для пользователей
//  НомерСтроки			 - Номер строки проверки
//  Отказ				 - Отказ
//  Предупреждать		 - Признак вывода предупреждения или сообщения (Истина вызывает метод Предупредить(); Ложь вызывает метод Сообщить() )
// 
// Возвращаемое значение:
//  Результат - Истина/Ложь
//
Функция Выбрано(Значение, ТекстПредупреждения = Неопределено, НомерСтроки = 0, Отказ = Ложь, Предупреждать = Ложь) Экспорт
	
	Результат = Истина;
	ТипЗначения = ТипЗнч(Значение);
	
	// Сначала примитивные типы
	Если Значение = Неопределено ИЛИ Значение = NULL Тогда
		Результат = Ложь;
	ИначеЕсли ТипЗначения=Тип("Булево") Тогда
		Результат = Истина;
	ИначеЕсли ТипЗначения=Тип("Число") 
		Тогда Если Значение = 0 Тогда 
			Результат = Ложь;
		КонецЕсли;
	ИначеЕсли ТипЗначения=Тип("Строка") Тогда
		Если СокрЛП(Значение)="" Тогда
			Результат = Ложь;
		КонецЕсли;
	ИначеЕсли ТипЗначения=Тип("Дата") Тогда
		Если Значение=Дата('00010101') Тогда
			Результат = Ложь;
		КонецЕсли;
	#Если Клиент Тогда
	ИначеЕсли ТипЗначения = Тип("ПолеВвода") И НЕ Выбрано(Значение.Значение) Тогда
		Результат = Ложь;
	#КонецЕсли
	
	// Для остальных будем считать значение пустым, если оно равно дефолтному значению своего типа
	Иначе
		Попытка
			Если Значение = Новый(ТипЗначения) Тогда
				Результат = Ложь;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Если Результат = Ложь Тогда
		Если ТекстПредупреждения <> Неопределено тогда
			#Если Клиент Тогда
			Если Предупреждать тогда
				ПоказатьПредупреждение(, "Не заполнено поле '" + ТекстПредупреждения + "'" + ?(НомерСтроки=0,""," в строке № " + НомерСтроки) + " !");
			Иначе
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнено поле '"+ТекстПредупреждения+"'"+?(НомерСтроки=0,""," в строке № "+НомерСтроки)+" !", СтатусСообщения.Важное);
			КонецЕсли;
			#КонецЕсли
		КонецЕсли;
		Отказ = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции


////////////////////////////////////////////////////////////////////////////////
// Интеграция с Telegram-бот

// Процедура отправки сообщения по Telegram
//
Процедура ОтправитьСообщениеTelegram(Пользователь, ТекстСообщения, СтилизованныйТекст = Ложь, ОтображатьСсылки = Ложь, IDСообщенияДляОтвета = 0, Клавиатура = "") Экспорт
	
	СтруктураПараметровПодключения = ПолучитьПараметрыПодключенияTelegram(Пользователь, Ложь);
	
	Если Не ЗначениеЗаполнено(СтруктураПараметровПодключения.НомерЧата) Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыЗапроса = "?chat_id=" + Формат(СтруктураПараметровПодключения.НомерЧата, "ЧГ=0") + "&text=" + ТекстСообщения;
	
	Если СтилизованныйТекст = Истина Тогда
		ПараметрыЗапроса = ПараметрыЗапроса + "&parse_mode=Markdown";
	КонецЕсли;
	
	Если ОтображатьСсылки = Истина Тогда
		ПараметрыЗапроса = ПараметрыЗапроса + "&disable_web_page_preview=True";
	КонецЕсли;
	
	Если IDСообщенияДляОтвета > 0 Тогда
		ПараметрыЗапроса = ПараметрыЗапроса + "&reply_to_message_id=" + Формат(IDСообщенияДляОтвета, "ЧГ=0");
	КонецЕсли;
	
	Если ПустаяСтрока(Клавиатура) Тогда 
		ПараметрыЗапроса = ПараметрыЗапроса + "&reply_markup=" + ПолучитьЗакрытуюКлавиатуру();
	Иначе
		ПараметрыЗапроса = ПараметрыЗапроса + "&reply_markup="+Клавиатура;
	КонецЕсли;
	
	Ресурс = "bot" + СтруктураПараметровПодключения.Токен + "/sendMessage" + ПараметрыЗапроса;
	Соединение = Новый HTTPСоединение(СтруктураПараметровПодключения.Сервер, 443,,,,,Новый ЗащищенноеСоединениеOpenSSL());
	Запрос = Новый HTTPЗапрос(Ресурс);
	Запрос.УстановитьТелоИзСтроки(ПараметрыЗапроса);
	Ответ = Соединение.ОтправитьДляОбработки(Запрос);
	
КонецПроцедуры

// Процедура отправки сообщения по Telegram
//
Процедура ОтправитьСообщениеTelegramПоChatID(НомерЧата, ТекстСообщения, СтилизованныйТекст = Ложь, ОтображатьСсылки = Ложь, IDСообщенияДляОтвета = 0, Клавиатура = "") Экспорт
	
	Если Не ЗначениеЗаполнено(НомерЧата) Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыЗапроса = "?chat_id=" + Формат(НомерЧата, "ЧГ=0") + "&text=" + ТекстСообщения;
	
	Если СтилизованныйТекст = Истина Тогда
		ПараметрыЗапроса = ПараметрыЗапроса + "&parse_mode=Markdown";
	КонецЕсли;
	
	Если ОтображатьСсылки = Истина Тогда
		ПараметрыЗапроса = ПараметрыЗапроса + "&disable_web_page_preview=True";
	КонецЕсли;
	
	Если IDСообщенияДляОтвета > 0 Тогда
		ПараметрыЗапроса = ПараметрыЗапроса + "&reply_to_message_id=" + Формат(IDСообщенияДляОтвета, "ЧГ=0");
	КонецЕсли;
	
	Если Не ПустаяСтрока(Клавиатура) Тогда 
		ПараметрыЗапроса = ПараметрыЗапроса + "&reply_markup="+Клавиатура;
	КонецЕсли;
	
	Ресурс = "bot" + ЯЯ_ВзаимодействиеССервисами.ПолучитьПредопределенныйОбъект("ТокенTelegram") + "/sendMessage" + ПараметрыЗапроса;
	Соединение = Новый HTTPСоединение(ЯЯ_ВзаимодействиеССервисами.ПолучитьПредопределенныйОбъект("СерверTelegram"), 443,,,,,Новый ЗащищенноеСоединениеOpenSSL());
	Запрос = Новый HTTPЗапрос(Ресурс);
	Запрос.УстановитьТелоИзСтроки(ПараметрыЗапроса);
	Ответ = Соединение.ОтправитьДляОбработки(Запрос);
	
КонецПроцедуры

// Процедура отправки сообщения по Telegram
//
Процедура ИзменитьКлавиатуру(НомерЧата, НомерСообщения, Клавиатура) Экспорт
	
	Токен = ЯЯ_ВзаимодействиеССервисами.ПолучитьПредопределенныйОбъект("ТокенTelegram");
	Сервер = ЯЯ_ВзаимодействиеССервисами.ПолучитьПредопределенныйОбъект("СерверTelegram");
	
	Ресурс = "bot" + Токен + "/editMessageReplyMarkup?chat_id=" + НомерЧата + "&message_id=" + НомерСообщения + "&reply_markup=" + Клавиатура;
	Соединение = Новый HTTPСоединение(Сервер, 443,,,,,Новый ЗащищенноеСоединениеOpenSSL());
	Запрос = Новый HTTPЗапрос(Ресурс);
	Ответ = Соединение.ОтправитьДляОбработки(Запрос);
	
КонецПроцедуры

// Функция возращяет параметры подключения к Телеграм
//
Функция ПолучитьПараметрыПодключенияTelegram(Пользователь, ОтправлятьАдминистратору = Истина)
	
	СтруктураПодключения = Новый Структура("Токен, НомерЧата, Сервер");
	
	Если ЗначениеЗаполнено(Пользователь) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Подключения.chat_id КАК ChatID
		|ИЗ
		|	РегистрСведений.ПодключенияTelegram КАК Подключения
		|ГДЕ
		|	Подключения.Пользователь = &Пользователь
		|	И Подключения.Актуальность = ИСТИНА
		|	И Подключения.АутентификацияПройдена = ИСТИНА";
		
		Запрос.УстановитьПараметр("Пользователь", Пользователь);
		
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() Тогда
			Если ОтправлятьАдминистратору Тогда
				СтруктураПодключения.Вставить("НомерЧата", ЯЯ_ВзаимодействиеССервисами.ПолучитьПредопределенныйОбъект("НомерЧатаАдминистратораTelegram"));
			Иначе
				Возврат СтруктураПодключения;
			КонецЕсли;
		Иначе
			Выборка = РезультатЗапроса.Выбрать();
			Пока Выборка.Следующий() Цикл
				СтруктураПодключения.Вставить("НомерЧата", Выборка.ChatID);
			КонецЦикла;
		КонецЕсли;
		
	Иначе
		Если ОтправлятьАдминистратору Тогда
			СтруктураПодключения.Вставить("НомерЧата", ЯЯ_ВзаимодействиеССервисами.ПолучитьПредопределенныйОбъект("НомерЧатаАдминистратораTelegram"));
		Иначе
			Возврат СтруктураПодключения;
		КонецЕсли;
	КонецЕсли;
	
	СтруктураПодключения.Вставить("Токен", ЯЯ_ВзаимодействиеССервисами.ПолучитьПредопределенныйОбъект("ТокенTelegram"));
	СтруктураПодключения.Вставить("Сервер", ЯЯ_ВзаимодействиеССервисами.ПолучитьПредопределенныйОбъект("СерверTelegram"));
	
	Возврат СтруктураПодключения;
	
КонецФункции

// Процедура отправки файлов по Telegram
//
Процедура ОтправитьФайл(Пользователь, chat_id, Параметр)
	
	Если Параметр.ИмяФайла = "" Тогда
		Возврат;
	КонецЕсли;
	
	ИмяФайла = Параметр.ИмяФайла;
	НазваниеФайла = Параметр.НазваниеФайла;
	
	СтруктураПараметровПодключения = ПолучитьПараметрыПодключенияTelegram(Пользователь);
	
	СтрокаСоединения = "/bot" + СтруктураПараметровПодключения.Токен + "/sendDocument";
	
	Boundary = "----"+Строка(Новый УникальныйИдентификатор());
	
	//Определяем массив для процедуры ОбъединитьФайлы
	МассивФайловДляОбъединения = Новый Массив;
	
	//Формируем начальный фрагмент файла POST-запроса
	ИмяФайлаОтправкиНачало = ПолучитьИмяВременногоФайла("txt");
	ФайлОтправкиНачало = Новый ЗаписьТекста(ИмяФайлаОтправкиНачало, КодировкаТекста.UTF8);
	
	//Формируем конечный фрагмент файла POST-запроса
	ИмяФайлаОтправкиКонец = ПолучитьИмяВременногоФайла("txt");
	ФайлаОтправкиКонец = Новый ЗаписьТекста(ИмяФайлаОтправкиКонец, КодировкаТекста.UTF8);
	
	ТекстДляОтправки = "";
	
	ТекстДляОтправки = ТекстДляОтправки + "--"+Boundary + Символы.ПС;
	ТекстДляОтправки = ТекстДляОтправки + "Content-Disposition: form-data; name=""chat_id""" + Символы.ПС + Символы.ПС;
	ТекстДляОтправки = ТекстДляОтправки + Формат(chat_id, "ЧГ=0") + Символы.ПС;
	
	ТекстДляОтправки = ТекстДляОтправки + "--"+Boundary + Символы.ПС;
	ТекстДляОтправки = ТекстДляОтправки + "Content-Disposition: form-data; name=""document""; filename=""" + НазваниеФайла + ".pdf" + """" + Символы.ПС;
	
	ФайлОтправкиНачало.ЗаписатьСтроку(ТекстДляОтправки );
	ФайлОтправкиНачало.Закрыть();
	
	МассивФайловДляОбъединения.Добавить(ИмяФайлаОтправкиНачало);
	
	МассивФайловДляОбъединения.Добавить(СокрЛП(ИмяФайла));
	
	ТекстДляОтправки = "" + Символы.ПС;
	ТекстДляОтправки = ТекстДляОтправки + "--"+Boundary+"--";
	ФайлаОтправкиКонец.ЗаписатьСтроку(ТекстДляОтправки);
	ФайлаОтправкиКонец.Закрыть();
	МассивФайловДляОбъединения.Добавить(ИмяФайлаОтправкиКонец);
	
	ИмяФайлаОтправки = ПолучитьИмяВременногоФайла("txt");
	ОбъединитьФайлы(МассивФайловДляОбъединения, ИмяФайлаОтправки);
	
	HTTPЗапрос = Новый HTTPЗапрос;
	Заголовки = Новый Соответствие;
	
	HTTPЗапрос.Заголовки.Вставить("Connection", "keep-alive");
	HTTPЗапрос.Заголовки.Вставить("Content-Type", "multipart/form-data; boundary="+Boundary);
	
	HTTPЗапрос.УстановитьИмяФайлаТела(ИмяФайлаОтправки);
	HTTPЗапрос.АдресРесурса = СтрокаСоединения;
	
	//ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL(Новый СертификатКлиентаWindows, Новый СертификатыУдостоверяющихЦентровWindows);
	HTTPСоединение = Новый HTTPСоединение(СтруктураПараметровПодключения.Сервер,,,,,, Новый ЗащищенноеСоединениеOpenSSL());
	
	Попытка
		ОтветHTTP = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	Исключение
		Сообщить(ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

