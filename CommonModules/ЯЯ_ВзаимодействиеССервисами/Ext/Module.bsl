// Процедура вывода списока команд группы в telegram-боте
//
Процедура ВывестиСписокКомандГруппы(Пользователь, Параметр, Группа)
	
	ОсновнойМассив = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ГруппыКомандTelegramКоманды.Команда.Описание КАК Описание,
	|	ГруппыКомандTelegramКоманды.Команда.ВыполняемоеДействие КАК ВыполняемоеДействие,
	|	ГруппыКомандTelegramКоманды.Команда.Параметр КАК Параметр
	|ИЗ
	|	Справочник.ГруппыКомандTelegram.Команды КАК ГруппыКомандTelegramКоманды
	|ГДЕ
	|	ГруппыКомандTelegramКоманды.Команда В
	|			(ВЫБРАТЬ
	|				РолиTelegramКоманды.Команда
	|			ИЗ
	|				Справочник.РолиTelegram.Команды КАК РолиTelegramКоманды
	|			ГДЕ
	|				РолиTelegramКоманды.Ссылка В
	|					(ВЫБРАТЬ
	|						ПользователиРолиTelegram.Роль
	|					ИЗ
	|						Справочник.Пользователи.РолиTelegram КАК ПользователиРолиTelegram
	|					ГДЕ
	|						ПользователиРолиTelegram.Ссылка = &Пользователь)
	|			СГРУППИРОВАТЬ ПО
	|				РолиTelegramКоманды.Команда)
	|	И ГруппыКомандTelegramКоманды.Ссылка = &Группа
	|
	|УПОРЯДОЧИТЬ ПО
	|	ГруппыКомандTelegramКоманды.НомерСтроки";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.УстановитьПараметр("Группа", Группа);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		МассивКнопок = Новый Массив();
		МассивКнопок.Добавить(Новый Структура("text, callback_data", Выборка.Описание, СокрЛП(Выборка.ВыполняемоеДействие + " " + Выборка.Параметр)));
		ОсновнойМассив.Добавить(МассивКнопок);
	КонецЦикла;
	
	Клавиатура = ПолучитьКлавиатуру(ОсновнойМассив);
	
	ТекстСообщения = "Выберете действие:";
	ОтправитьСообщениеTelegram(Пользователь, ТекстСообщения,,,,Клавиатура);
	
КонецПроцедуры

Процедура ПолучитьОтчетПоКоманде(ИмяКоманды, Пользователь, СтруктураПараметров)
	
	ХранилищеВнешнихМакетов = ЯЯ_ВзаимодействиеССервисами.ПолучитьПредопределенныйОбъект("ХранилищеВнешнихМакетов");
	ОбъектВнешнейОбработки = ДополнительныеОтчетыИОбработки.ПолучитьОбъектВнешнейОбработки(ХранилищеВнешнихМакетов);
	
	ДокументРезультат = Неопределено;
	
	Если ИмяКоманды = "DocsMy" Тогда
		ДокументРезультат = ОбъектВнешнейОбработки.ПолучитьТабличныйДокумент_DocsMy(Пользователь);
	ИначеЕсли ИмяКоманды = "DocsNew" Тогда
		ДокументРезультат = ОбъектВнешнейОбработки.ПолучитьТабличныйДокумент_DocsNew(Пользователь);
	ИначеЕсли ИмяКоманды = "DocsOnAppr" Тогда
		ДокументРезультат = ОбъектВнешнейОбработки.ПолучитьТабличныйДокумент_DocsOnAppr(Пользователь);
	ИначеЕсли ИмяКоманды = "DocsInfo" Тогда
		ДокументРезультат = ОбъектВнешнейОбработки.ПолучитьТабличныйДокумент_DocsInfo(Пользователь, СтруктураПараметров.Параметр);
	ИначеЕсли ИмяКоманды = "DocsNewMonth" Тогда
		ДокументРезультат = ОбъектВнешнейОбработки.ПолучитьТабличныйДокумент_DocsNewMonth(Пользователь);
	ИначеЕсли ИмяКоманды = "DocsPrevMonth" Тогда
		ДокументРезультат = ОбъектВнешнейОбработки.ПолучитьТабличныйДокумент_DocsPrevMonth(Пользователь);
	ИначеЕсли ИмяКоманды = "TasksMy" Тогда
		ДокументРезультат = ОбъектВнешнейОбработки.ПолучитьТабличныйДокумент_TasksMy(Пользователь);
	ИначеЕсли ИмяКоманды = "TasksIssued" Тогда
		ДокументРезультат = ОбъектВнешнейОбработки.ПолучитьТабличныйДокумент_TasksIssued(Пользователь);
	ИначеЕсли ИмяКоманды = "StatisticAll" Тогда
		ДокументРезультат = ОбъектВнешнейОбработки.ПолучитьТабличныйДокумент_StatisticAll(Пользователь);
	КонецЕсли;
		
	Если ДокументРезультат = Неопределено Тогда
		ТекстСообщения = "Нет данных для вывода.";
		ОтправитьСообщениеTelegram(Пользователь, ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ИмяФайла = ПолучитьИмяВременногоФайла("PDF");
	ДокументРезультат.Записать(ИмяФайла, ТипФайлаТабличногоДокумента.PDF);
	
	Параметр = Новый Структура;
	Параметр.Вставить("Пользователь", Пользователь);
	Параметр.Вставить("ИмяФайла", ИмяФайла);
	Параметр.Вставить("НазваниеФайла", ИмяКоманды + "_" + Формат(ТекущаяДата(), "ДФ=yyyy-MM-dd_HH-mm-ss"));
	
	ОтправитьФайл(Пользователь, СтруктураПараметров.ChatID, Параметр);
	
	ТекстСообщения = "Для подолжения работы нажмите /start";
	ОтправитьСообщениеTelegram(Пользователь, ТекстСообщения);
	
КонецПроцедуры

