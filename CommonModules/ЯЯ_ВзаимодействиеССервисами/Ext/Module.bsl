// Процедура получение сообщений по Telegram
//
Процедура ПоказатьСообщение(Смещение = 0, КоличествоОбновлений = 100, Таймаут = 0) Экспорт
	
	Если Смещение > 0 Тогда
		ПараметрыЗапроса = "?offset="+Формат(Смещение, "ЧГ=0");
	КонецЕсли;
	
	Если Не КоличествоОбновлений = 100 Тогда
		Если ЗначениеЗаполнено(ПараметрыЗапроса) Тогда
			ПараметрыЗапроса = "&limit="+Формат(КоличествоОбновлений, "ЧГ=0");
		Иначе 
			ПараметрыЗапроса = "?limit="+Формат(КоличествоОбновлений, "ЧГ=0");
		КонецЕсли;
	КонецЕсли;
	
	Если Таймаут > 0 Тогда 
		Если ЗначениеЗаполнено(ПараметрыЗапроса) Тогда
			ПараметрыЗапроса = "&timeout="+Формат(Таймаут, "ЧГ=0");
		Иначе
			ПараметрыЗапроса = "?timeout="+Формат(Таймаут, "ЧГ=0");
		КонецЕсли;
	КонецЕсли;
	
	Токен = ПолучитьПредопределенныйОбъект("ТокенTelegram");
	Сервер = ПолучитьПредопределенныйОбъект("СерверTelegram");
	
	Ресурс = "bot" + Токен + "/getUpdates" + ПараметрыЗапроса;
	Соединение  =  Новый HTTPСоединение(Сервер,443,,,,,Новый ЗащищенноеСоединениеOpenSSL());
	Запрос = Новый HTTPЗапрос(Ресурс);
	Ответ = Соединение.Получить(Запрос);
	ДвоичныеДанныеОтвета = Ответ.ПолучитьТелоКакДвоичныеДанные();
	
	ПрочитатьДвоичныеДанныеОтвета(ДвоичныеДанныеОтвета);
	
КонецПроцедуры

// функция выдает строковое представление существующих команд
//
Функция СписокКоманд(Пользователь)
	
	ТаблицаПонимаемыхКоманд = ПолучитьТаблицуПонимаемыхКоманд(Пользователь);
	
	СтрВозврата = "";
	
	Для Каждого Стр Из ТаблицаПонимаемыхКоманд Цикл
		Если Стр.Выводить Тогда
			СтрВозврата = СтрВозврата + ?(СтрВозврата <> "", Символы.ПС, "") + Стр.Имя + " - " + Стр.Описание;
		КонецЕсли;
	КонецЦикла;
	
	Возврат СтрВозврата;
	
КонецФункции

// Процедура получения двоичных данных ответа и сормирования дерева значений
//
Процедура ПрочитатьДвоичныеДанныеОтвета(ДвоичныеДанныеОтвета)
	
	ИмяФайла = ПолучитьИмяВременногоФайла("tgm");
	ДвоичныеДанныеОтвета.Записать(ИмяФайла);
	ДеревоЗн = Новый ДеревоЗначений;
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.ОткрытьФайл(ИмяФайла);
	СтрДерево = ДеревоЗн;
	Пока ЧтениеJSON.Прочитать() Цикл
		СтрДерево = СформироватьДерево(ДеревоЗн, СтрДерево, ЧтениеJSON,, Ложь);
	КонецЦикла;
	ЧтениеJSON.Закрыть();
	
	ЗаполнитьДанные(ДеревоЗн);
	
КонецПроцедуры

Функция СформироватьДерево(ДеревоЗн, СтрДерево, ЧтениеJSON, Знач ИмяКолонки = Неопределено, Прочитать = Истина)
	
	Если Прочитать Тогда
		ЧтениеJSON.Прочитать();
	КонецЕсли;
	TипJSON = ЧтениеJSON.ТипТекущегоЗначения;
	Если TипJSON = ТипЗначенияJSON.НачалоОбъекта ИЛИ TипJSON = ТипЗначенияJSON.НачалоМассива Тогда
		НовСтр = СтрДерево.Строки.Добавить();
		Возврат СформироватьДерево(ДеревоЗн, НовСтр, ЧтениеJSON);
	ИначеЕсли TипJSON = ТипЗначенияJSON.ИмяСвойства Тогда
		Возврат СформироватьДерево(ДеревоЗн, СтрДерево, ЧтениеJSON, ЧтениеJSON.ТекущееЗначение);
	ИначеЕсли TипJSON = ТипЗначенияJSON.Число ИЛИ TипJSON = ТипЗначенияJSON.Строка ИЛИ TипJSON = ТипЗначенияJSON.Булево ИЛИ TипJSON = ТипЗначенияJSON.Null Тогда 
		Если ДеревоЗн.Колонки.Найти(ИмяКолонки) = Неопределено Тогда
			ДеревоЗн.Колонки.Добавить(ИмяКолонки);
		КонецЕсли;
		СтрДерево[ИмяКолонки] = ЧтениеJSON.ТекущееЗначение;
		Возврат СформироватьДерево(ДеревоЗн, СтрДерево, ЧтениеJSON);
	ИначеЕсли TипJSON = ТипЗначенияJSON.Комментарий Тогда
		Если ДеревоЗн.Колонки.Найти("Комментарий") = Неопределено Тогда
			ДеревоЗн.Колонки.Добавить("Комментарий");
		КонецЕсли;
		СтрДерево.Комментарий = ЧтениеJSON.ТекущееЗначение;
		Возврат СформироватьДерево(ДеревоЗн, СтрДерево, ЧтениеJSON);
	ИначеЕсли СтрДерево <> Неопределено Тогда
		Возврат СтрДерево.Родитель;
	КонецЕсли;
	
КонецФункции

// Процедура заполнения регистра сведений команд и их инициализация
//
Процедура ЗаполнитьДанные(ДеревоЗн)
	
	Для Каждого СтрокаОк Из ДеревоЗн.Строки Цикл // oк
		
		Для Каждого СтрокаНовая Из СтрокаОк.Строки Цикл//
			
			Для Каждого СтрокаОбновление Из СтрокаНовая.Строки Цикл // update_id
				
				Для Каждого СтрокаСообщение Из СтрокаОбновление.Строки Цикл // message_id
					
					date = СтрокаСообщение.date;
					Команда = СокрЛП(СтрокаСообщение.text);
					Параметр = "";
					
					Попытка
						data = СтрокаСообщение.data;
						chat_instance = СтрокаСообщение.chat_instance;
					Исключение
						data = "";
						chat_instance = "";
					КонецПопытки;
					
					ПозицияПараметра = Найти(Команда, " ");
					
					Если ПозицияПараметра <> 0 Тогда
						Параметр = СокрЛП(Сред(Команда, ПозицияПараметра + 1));
						Команда = Лев(Команда, ПозицияПараметра - 1);
					КонецЕсли;
					
					Для Каждого СтрокаИнфо Из СтрокаСообщение.Строки Цикл // message_id
						
						chat_id = СтрокаИнфо.id;
						
						Если ЗначениеЗаполнено(chat_id) И chat_id > 0 Тогда
							
							НаборЗаписей = РегистрыСведений.КомандыПользователей.СоздатьНаборЗаписей();
							НаборЗаписей.Отбор.chat_id.Установить(chat_id);
							НаборЗаписей.Отбор.date.Установить(date);
							НаборЗаписей.Прочитать();
							
							Если НаборЗаписей.Количество() > 0 Тогда
								
								Для Каждого Запись Из НаборЗаписей Цикл
									Если НЕ Запись.Выполнено Тогда
										Запись.Выполнено = ВыполнитьКомандуБота(Запись);
										НаборЗаписей.Записать();
									КонецЕсли;
								КонецЦикла;
								
								НаборЗаписей = Неопределено;
								
							Иначе
								
								НаборЗаписейЗ = РегистрыСведений.КомандыПользователей.СоздатьМенеджерЗаписи();
								НаборЗаписейЗ.chat_id = chat_id;
								НаборЗаписейЗ.date = date;
								НаборЗаписейЗ.Команда = Команда;
								НаборЗаписейЗ.Параметр = Параметр;
								НаборЗаписейЗ.Выполнено = ВыполнитьКомандуБота(НаборЗаписейЗ);
								НаборЗаписейЗ.Записать();
								
							КонецЕсли;
							
							Если ЗначениеЗаполнено(chat_instance) И ЗначениеЗаполнено(data) Тогда
								
								СтрокаСобытий = СтрокаСообщение.Строки[1];
								date = СтрокаСобытий.date;
								message_id = СтрокаСобытий.message_id;
								
								Команда = СокрЛП(data);
								ПозицияПараметра = Найти(Команда, " ");
								
								Если ПозицияПараметра <> 0 Тогда
									Параметр = СокрЛП(Сред(Команда, ПозицияПараметра + 1));
									Команда = Лев(Команда, ПозицияПараметра - 1);
								КонецЕсли;
								
								НаборЗаписей = РегистрыСведений.КомандыПользователей.СоздатьНаборЗаписей();
								НаборЗаписей.Отбор.chat_id.Установить(chat_id);
								НаборЗаписей.Отбор.date.Установить(date);
								НаборЗаписей.Прочитать();
								
								Если НаборЗаписей.Количество() > 0 Тогда
									
									Для Каждого Запись Из НаборЗаписей Цикл
										Если НЕ Запись.Выполнено Тогда
											Запись.Выполнено = ВыполнитьКомандуБота(Запись);
											НаборЗаписей.Записать();
										КонецЕсли;
									КонецЦикла;
									
									НаборЗаписей = Неопределено;
									
								Иначе
									
									НаборЗаписейЗ = РегистрыСведений.КомандыПользователей.СоздатьМенеджерЗаписи();
									НаборЗаписейЗ.chat_id = chat_id;
									НаборЗаписейЗ.date = date;
									НаборЗаписейЗ.Команда = Команда;
									НаборЗаписейЗ.Параметр = Параметр;
									НаборЗаписейЗ.Выполнено = ВыполнитьКомандуБота(НаборЗаписейЗ);
									НаборЗаписейЗ.Записать();
									
									ОсновнойМассив = Новый Массив;
									МассивКнопок = Новый Массив;
									МассивКнопок.Добавить(Новый Структура("text, callback_data", "Выбрано: " + Параметр, "Выбор сделан"));
									ОсновнойМассив.Добавить(МассивКнопок);
									Клавиатура = ПолучитьКлавиатуру(ОсновнойМассив);
									
									ИзменитьКлавиатуру(Формат(chat_id, "ЧГ=0"), Формат(message_id, "ЧГ=0"), Клавиатура);
									
								КонецЕсли;
								
							КонецЕсли;
							
							Прервать;
							
						КонецЕсли;
						
					КонецЦикла;
					
				КонецЦикла;
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла
	
КонецПроцедуры

// Функция определяет пользователя системы по номеру чата
//
Функция ПолучитьПользовательПоChatID(chat_id) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПодключенияTelegram.Пользователь КАК Пользователь,
		|	ПодключенияTelegram.Актуальность,
		|	ПодключенияTelegram.АутентификацияПройдена
		|ИЗ
		|	РегистрСведений.ПодключенияTelegram КАК ПодключенияTelegram
		|ГДЕ
		|	ПодключенияTelegram.chat_id = &НомерЧата";
	
	Запрос.УстановитьПараметр("НомерЧата", chat_id);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		Если Выборка.Актуальность И Выборка.АутентификацияПройдена Тогда
			Возврат Выборка.Пользователь;
		ИначеЕсли Не Выборка.Актуальность Тогда
			ТекстСообщения = "Текущий пользователь заблокирован. Обратитесь к администратору системы.";
		ИначеЕсли Выборка.Актуальность И Не Выборка.АутентификацияПройдена Тогда
			ТекстСообщения = ":( Неопознанная ошибка. Обратитесь к администратору системы.";
		КонецЕсли;
		
	Иначе 
		
		ТекстСообщения = "Текущий пользователь не зарегистрирован. Необходимо пройти процедуру регистрации.
		|Для этого необходимо отправить команду /RegMail и указать корпоративную почту.
		|Пример команды: /RegMail v.pupkin@brsm-nafta.com";
		
	КонецЕсли;
	
	ОтправитьСообщениеTelegramПоChatID(chat_id, ТекстСообщения);
	
	Возврат Неопределено;
	
КонецФункции

// Функция определяет пользователя системы по номеру чата
//
Функция ПолучитьChatIDПоПользователю(Пользователь) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПодключенияTelegram.chat_id КАК НомерЧата
		|ИЗ
		|	РегистрСведений.ПодключенияTelegram КАК ПодключенияTelegram
		|ГДЕ
		|	ПодключенияTelegram.Пользователь = &Пользователь";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Возврат Выборка.НомерЧата;
		
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

// функция возращяет таблицу значений понимающих команд
//
Функция ПолучитьТаблицуПонимаемыхКоманд(Пользователь)
	
	ТаблицаПонимаемыхКоманд = Новый ТаблицаЗначений;
	
	ОписаниеСтроки = Новый ОписаниеТипов("Строка", ,Новый КвалификаторыСтроки(200));
	
	ТаблицаПонимаемыхКоманд.Колонки.Добавить("Имя", 				ОписаниеСтроки);
	ТаблицаПонимаемыхКоманд.Колонки.Добавить("ВыполняемоеДействие", ОписаниеСтроки);
	ТаблицаПонимаемыхКоманд.Колонки.Добавить("Описание", 			ОписаниеСтроки);
	ТаблицаПонимаемыхКоманд.Колонки.Добавить("Параметр", 			ОписаниеСтроки);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РолиTelegramКоманды.Команда.Наименование КАК Имя,
		|	РолиTelegramКоманды.Команда.ВыполняемоеДействие КАК ВыполняемоеДействие,
		|	РолиTelegramКоманды.Команда.Описание КАК Описание,
		|	РолиTelegramКоманды.Команда.Параметр КАК Параметр
		|ИЗ
		|	(ВЫБРАТЬ
		|		ПользователиРолиTelegram.Роль КАК Роль
		|	ИЗ
		|		Справочник.Пользователи.РолиTelegram КАК ПользователиРолиTelegram
		|	ГДЕ
		|		ПользователиРолиTelegram.Ссылка = &Пользователь) КАК Роли
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.РолиTelegram.Команды КАК РолиTelegramКоманды
		|		ПО Роли.Роль = РолиTelegramКоманды.Ссылка
		|ГДЕ
		|	РолиTelegramКоманды.Команда.Выводить
		|
		|СГРУППИРОВАТЬ ПО
		|	РолиTelegramКоманды.Команда.Наименование,
		|	РолиTelegramКоманды.Команда.ВыполняемоеДействие,
		|	РолиTelegramКоманды.Команда.Описание,
		|	РолиTelegramКоманды.Команда.Параметр";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = ТаблицаПонимаемыхКоманд.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		НоваяСтрока.ВыполняемоеДействие = НРег(Выборка.ВыполняемоеДействие);
		
		НоваяСтрока = ТаблицаПонимаемыхКоманд.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		НоваяСтрока.ВыполняемоеДействие = НРег("/" + Выборка.ВыполняемоеДействие);
	КонецЦикла;
	
	Возврат ТаблицаПонимаемыхКоманд;
	
КонецФункции

// функция инициализирует выполнение понимаемых команд
//
Функция ВыполнитьКомандуБота(ЗаписьРегистра)
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ChatID", ЗаписьРегистра.chat_id);
	СтруктураПараметров.Вставить("Команда", ЗаписьРегистра.Команда);
	СтруктураПараметров.Вставить("Параметр", ЗаписьРегистра.Параметр);
	
	Если ЯвляетсяКомандойДляРегистрации(СтруктураПараметров.Команда) Тогда
		РегистрацияПользователя(СтруктураПараметров);
		Возврат Истина;
	КонецЕсли;
	
	Пользователь = ПолучитьПользовательПоChatID(СтруктураПараметров.ChatID);
	
	Если Не ЗначениеЗаполнено(Пользователь) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ЯвляетсяСтартовойКомандой(СтруктураПараметров.Команда) Тогда
		СтартовоеДействие(СтруктураПараметров, Пользователь);
		Возврат Истина;
	КонецЕсли;
	
	ТаблицаПонимаемыхКоманд = ПолучитьТаблицуПонимаемыхКоманд(Пользователь);
	
	МассивНайденныхСтрок = ТаблицаПонимаемыхКоманд.НайтиСтроки(Новый Структура("ВыполняемоеДействие", НРег(СтруктураПараметров.Команда)));
	
	Если МассивНайденныхСтрок.Количество() > 0 Тогда
		
		Для Каждого Стр Из МассивНайденныхСтрок Цикл
			
			Если Стр.ВыполняемоеДействие = "showlist" 
				Или Стр.ВыполняемоеДействие = "/showlist" Тогда
				
				ShowList(Пользователь, СтруктураПараметров.Параметр);
				
			ИначеЕсли Стр.ВыполняемоеДействие = "showwelcome"
				Или Стр.ВыполняемоеДействие = "/showwelcome" Тогда
				
				ShowWelcome(Пользователь, СтруктураПараметров.Параметр);
				
			ИначеЕсли Стр.ВыполняемоеДействие = "showfaq" 
				Или Стр.ВыполняемоеДействие = "/showfaq" Тогда
				
				ShowFAQ(Пользователь, СтруктураПараметров.Параметр);
				
			ИначеЕсли Стр.ВыполняемоеДействие = "showinfo"
				Или Стр.ВыполняемоеДействие = "/showinfo" Тогда
				
				ShowInfo(Пользователь, СтруктураПараметров.Параметр);
				
			ИначеЕсли Стр.ВыполняемоеДействие = "showfeedback"
				Или Стр.ВыполняемоеДействие = "/showfeedback" Тогда
				
				ShowFeedback(Пользователь, СтруктураПараметров.Параметр);
				
			ИначеЕсли Стр.ВыполняемоеДействие = "showlistdocs"
				Или Стр.ВыполняемоеДействие = "/showlistdocs" Тогда
				
				ВывестиСписокКомандГруппы(Пользователь, СтруктураПараметров.Параметр, Справочники.ГруппыКомандTelegram.Документы);
				
			ИначеЕсли Стр.ВыполняемоеДействие = "showlistadds"
				Или Стр.ВыполняемоеДействие = "/showlistadds" Тогда
				
				ВывестиСписокКомандГруппы(Пользователь, СтруктураПараметров.Параметр, Справочники.ГруппыКомандTelegram.Дополнительно);
				
			ИначеЕсли Стр.ВыполняемоеДействие = "showlisttasks"
				Или Стр.ВыполняемоеДействие = "/showlisttasks" Тогда
				
				ВывестиСписокКомандГруппы(Пользователь, СтруктураПараметров.Параметр, Справочники.ГруппыКомандTelegram.Задачи);
				
			ИначеЕсли Стр.ВыполняемоеДействие = "showlistreports"
				Или Стр.ВыполняемоеДействие = "/showlistreports" Тогда
				
				ВывестиСписокКомандГруппы(Пользователь, СтруктураПараметров.Параметр, Справочники.ГруппыКомандTelegram.Отчеты);
				
			ИначеЕсли Стр.ВыполняемоеДействие = "showlistsettings"
				Или Стр.ВыполняемоеДействие = "/showlistsettings" Тогда
				
				ВывестиСписокКомандГруппы(Пользователь, СтруктураПараметров.Параметр, Справочники.ГруппыКомандTelegram.Настройки);
				
			ИначеЕсли Стр.ВыполняемоеДействие = "docsmy"
				Или Стр.ВыполняемоеДействие = "/docsmy" Тогда
				
				DocsMy(Пользователь, СтруктураПараметров);
				
			ИначеЕсли Стр.ВыполняемоеДействие = "docsnew"
				Или Стр.ВыполняемоеДействие = "/docsnew" Тогда
				
				DocsNew(Пользователь, СтруктураПараметров);
				
			ИначеЕсли Стр.ВыполняемоеДействие = "docsonappr"
				Или Стр.ВыполняемоеДействие = "/docsonappr" Тогда
				
				DocsOnAppr(Пользователь, СтруктураПараметров);
				
			ИначеЕсли Стр.ВыполняемоеДействие = "docsinfo"
				Или Стр.ВыполняемоеДействие = "/docsinfo" Тогда
				
				DocsInfo(Пользователь, СтруктураПараметров);
				
			ИначеЕсли Стр.ВыполняемоеДействие = "docsinfotext"
				Или Стр.ВыполняемоеДействие = "/docsinfotext" Тогда
				
				DocsInfoText(Пользователь, СтруктураПараметров);
				
			ИначеЕсли Стр.ВыполняемоеДействие = "docsnewmonth"
				Или Стр.ВыполняемоеДействие = "/docsnewmonth" Тогда
				
				DocsNewMonth(Пользователь, СтруктураПараметров);
				
			ИначеЕсли Стр.ВыполняемоеДействие = "docsprevmonth"
				Или Стр.ВыполняемоеДействие = "/docsprevmonth" Тогда
				
				DocsPrevMonth(Пользователь, СтруктураПараметров);
				
			ИначеЕсли Стр.ВыполняемоеДействие = "tasksmy"
				Или Стр.ВыполняемоеДействие = "/tasksmy" Тогда
				
				TasksMy(Пользователь, СтруктураПараметров);
				
			ИначеЕсли Стр.ВыполняемоеДействие = "tasksissued"
				Или Стр.ВыполняемоеДействие = "/tasksissued" Тогда
				
				TasksIssued(Пользователь, СтруктураПараметров);
				
			ИначеЕсли Стр.ВыполняемоеДействие = "statisticall"
				Или Стр.ВыполняемоеДействие = "/statisticall" Тогда
				
				StatisticAll(Пользователь, СтруктураПараметров);
				
			Иначе
				
				ВывестиОшибку(Пользователь, СтруктураПараметров.Параметр);
				
			КонецЕсли;
			
		КонецЦикла;
		
	Иначе
		
		ВывестиОшибку(Пользователь, СтруктураПараметров.Параметр);
		
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

// Функция возращяет параметры клавиатуры для сообщения
//
Функция ПолучитьКлавиатуру(МассивКнопок)
	
	ПутьКФайлу = ПолучитьИмяВременногоФайла("txt");
	
	Структура = Новый Структура;
	Структура.Вставить("inline_keyboard", МассивКнопок);
	Структура.Вставить("one_time_keyboard" , Истина);
	Структура.Вставить("resize_keyboard", Истина);
	
	Файл = Новый ТекстовыйДокумент;
	Файл.Записать(ПутьКФайлу, "UTF-8");
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.ОткрытьФайл(ПутьКФайлу);
	ЗаписатьJSON(ЗаписьJSON, Структура);
	ЗаписьJSON.Закрыть();
	
	Файл.Прочитать(ПутьКФайлу, "UTF-8");
	
	ТекстJSON = Файл.ПолучитьТекст();
	ТекстJSON = СтрЗаменить(ТекстJSON, "Истина", "True");
	
	Возврат ТекстJSON;
	
КонецФункции

// Функция возращяет параметры закрытие клавиатуры для сообщения
//
Функция ПолучитьЗакрытуюКлавиатуру()
	
	ПутьКФайлу = ПолучитьИмяВременногоФайла("txt");
	
	Структура = Новый Структура;
	Структура.Вставить("remove_keyboard" , Истина);
	
	Файл = Новый ТекстовыйДокумент;
	Файл.Записать(ПутьКФайлу, "UTF-8");
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.ОткрытьФайл(ПутьКФайлу);
	ЗаписатьJSON(ЗаписьJSON, Структура);
	ЗаписьJSON.Закрыть();
	
	Файл.Прочитать(ПутьКФайлу, "UTF-8");
	
	ТекстJSON = Файл.ПолучитьТекст();
	ТекстJSON = СтрЗаменить(ТекстJSON, "Истина", "True");
	
	Возврат ТекстJSON;
	
КонецФункции

// Функция проверяет команду на соответствие регистрационным командам
//
Функция ЯвляетсяКомандойДляРегистрации(Команда)
	
	СписокКоманда = Новый СписокЗначений;
	СписокКоманда.Добавить("/regmail");
	СписокКоманда.Добавить("/regpass");
	
	Если СписокКоманда.НайтиПоЗначению(НРег(Команда)) <> Неопределено Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

// Функция проверяет команду на соответствие стартовым командам
//
Функция ЯвляетсяСтартовойКомандой(Команда)
	
	СписокКоманда = Новый СписокЗначений;
	СписокКоманда.Добавить("/start");
	
	Если СписокКоманда.НайтиПоЗначению(НРег(Команда)) <> Неопределено Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

// Процедура регистрации нового пользователя в telegram-боте
//
Процедура РегистрацияПользователя(СтруктураПараметров)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИСТИНА
		|ИЗ
		|	РегистрСведений.ПодключенияTelegram КАК ПодключенияTelegram
		|ГДЕ
		|	ПодключенияTelegram.chat_id = &chat_id
		|	И ПодключенияTelegram.Актуальность
		|	И ПодключенияTelegram.АутентификацияПройдена";
	
	Запрос.УстановитьПараметр("chat_id", СтруктураПараметров.ChatID);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		ТекстСообщения = "Текущий пользователь активный. Регистрация не нужна.";
		ОтправитьСообщениеTelegramПоChatID(СтруктураПараметров.ChatID, ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	Если НРег(СтруктураПараметров.Команда) = "/regmail" Тогда 
		
		Если Не ЗначениеЗаполнено(СтруктураПараметров.Параметр) Тогда
			
			ТекстСообщения = "Не верно указана почта.
			|Для этого необходимо отправить команду /RegMail и указать корпоративную почту.
			|Пример команды: /RegMail v.pupkin@brsm-nafta.com";
			
			ОтправитьСообщениеTelegramПоChatID(СтруктураПараметров.ChatID, ТекстСообщения);
			Возврат;
			
		КонецЕсли;
		
		Запись = РегистрыСведений.ИсторияРегистрацииTelegram.СоздатьМенеджерЗаписи();
		Запись.Период = ТекущаяДата();
		Запись.chat_id = СтруктураПараметров.ChatID;
		Запись.СобытиеРегистрации = Перечисления.СобытияРегистрацииTelegram.НачалоРегистрации;
		Запись.Команда = СтруктураПараметров.Команда;
		Запись.Параметр = СтруктураПараметров.Параметр;
		Запись.Пользователь = Справочники.Пользователи.ПустаяСсылка();
		
		Запись.Записать();
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	ПользователиКонтактнаяИнформация.Ссылка КАК Пользователь
		               |ИЗ
		               |	Справочник.Пользователи.КонтактнаяИнформация КАК ПользователиКонтактнаяИнформация
		               |ГДЕ
		               |	ПользователиКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты)
		               |	И ПользователиКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailПользователя)
		               |	И ПользователиКонтактнаяИнформация.Представление = &Почта";
		
		Запрос.УстановитьПараметр("Почта", СтруктураПараметров.Параметр);
		
		РезультатЗапроса = Запрос.Выполнить();
		Выборка = РезультатЗапроса.Выбрать();
		
		Количество = Выборка.Количество();
		Если Количество = 0 Тогда
			
			Запись = РегистрыСведений.ИсторияРегистрацииTelegram.СоздатьМенеджерЗаписи();
			Запись.Период = ТекущаяДата();
			Запись.chat_id = СтруктураПараметров.ChatID;
			Запись.СобытиеРегистрации = Перечисления.СобытияРегистрацииTelegram.НевернаяПочта;
			Запись.Команда = СтруктураПараметров.Команда;
			Запись.Параметр = СтруктураПараметров.Параметр;
			Запись.Пользователь = Справочники.Пользователи.ПустаяСсылка();
			
			ТекстСообщения = "Почта не найдена в корпоративной базе.
			|Обратитесь к администратору системы";
			
			ОтправитьСообщениеTelegramПоChatID(СтруктураПараметров.ChatID, ТекстСообщения);
			Возврат;
			
		ИначеЕсли Количество = 1 Тогда
			
			Выборка.Следующий();
			
			Запись = РегистрыСведений.ИсторияРегистрацииTelegram.СоздатьМенеджерЗаписи();
			Запись.Период = ТекущаяДата();
			Запись.chat_id = СтруктураПараметров.ChatID;
			Запись.СобытиеРегистрации = Перечисления.СобытияРегистрацииTelegram.НайденаПочта;
			Запись.Команда = СтруктураПараметров.Команда;
			Запись.Параметр = СтруктураПараметров.Параметр;
			Запись.Пользователь = Выборка.Пользователь;
			
			Запись.Записать();
			
			// Отправка письма с инструкцией
			УчетнаяЗапись = Справочники.УчетныеЗаписиЭлектроннойПочты.НайтиПоНаименованию("Системная учетная запись");
			
			ПараметрыПисьма = Новый Структура;
			СписокФайлов = Новый Массив;
			
			Пароль = Формат(Выборка.Пользователь.ПарольTelegram, "ЧЦ=6; ЧДЦ=; ЧГ=");
			
			Текст = "Добрый день,
			|
			|Ваш секретный код: " + Пароль + "
			|Для продолжения активации учетной записи для работы с telegram-бот необходимо
			|отправить в telegram:
			|
			|/RegPass " + Пароль + "
			|
			|Это информационное письмо. На него не нужно отвечать!";
			
			ПараметрыПисьма.Вставить("УчетнаяЗапись", УчетнаяЗапись);
			ПараметрыПисьма.Вставить("Кому", СтруктураПараметров.Параметр);
			ПараметрыПисьма.Вставить("Тема", "Регистрация в Telegram для 1С:Документооборот");
			ПараметрыПисьма.Вставить("Тело", Текст);
			ПараметрыПисьма.Вставить("Вложения", СписокФайлов);
			
			РаботаСПочтовымиСообщениями.ОтправитьПочтовоеСообщение(УчетнаяЗапись, ПараметрыПисьма);
			
			ТекстСообщения = "На корпоративную почту было отправлено письмо с продолжением регистрации.
			|Если в течении 5 минут письмо не пришло, то обратитесь к администратору системы";
			
			ОтправитьСообщениеTelegramПоChatID(СтруктураПараметров.ChatID, ТекстСообщения);
			
			Запись = РегистрыСведений.ИсторияРегистрацииTelegram.СоздатьМенеджерЗаписи();
			Запись.Период = ТекущаяДата()+1;
			Запись.chat_id = СтруктураПараметров.ChatID;
			Запись.СобытиеРегистрации = Перечисления.СобытияРегистрацииTelegram.ОтправкаПисьмаСПаролем;
			Запись.Команда = СтруктураПараметров.Команда;
			Запись.Параметр = Пароль;
			Запись.Пользователь = Выборка.Пользователь;
			
			Запись.Записать();
			
		ИначеЕсли Количество > 1 Тогда
			
			Запись = РегистрыСведений.ИсторияРегистрацииTelegram.СоздатьМенеджерЗаписи();
			Запись.Период = ТекущаяДата();
			Запись.chat_id = СтруктураПараметров.ChatID;
			Запись.СобытиеРегистрации = Перечисления.СобытияРегистрацииTelegram.ДублированиеПочты;
			Запись.Команда = СтруктураПараметров.Команда;
			Запись.Параметр = СтруктураПараметров.Параметр;
			Запись.Пользователь = Справочники.Пользователи.ПустаяСсылка();
			
			Запись.Записать();
			
			ТекстСообщения = "Найдено несколько пользователей с текущей почтой.
			|Обратитесь к администратору системы";
			
			ОтправитьСообщениеTelegramПоChatID(СтруктураПараметров.ChatID, ТекстСообщения);
			Возврат;
			
		КонецЕсли;
		
	ИначеЕсли НРег(СтруктураПараметров.Команда) = "/regpass" Тогда
		
		Если СтруктураПараметров.Параметр = "" Тогда
			
			Запись = РегистрыСведений.ИсторияРегистрацииTelegram.СоздатьМенеджерЗаписи();
			Запись.Период = ТекущаяДата();
			Запись.chat_id = СтруктураПараметров.ChatID;
			Запись.СобытиеРегистрации = Перечисления.СобытияРегистрацииTelegram.НеверныйПароль;
			Запись.Команда = СтруктураПараметров.Команда;
			Запись.Параметр = СтруктураПараметров.Параметр;
			Запись.Пользователь = Справочники.Пользователи.ПустаяСсылка();
			
			Запись.Записать();
			
			ТекстСообщения = "Укажите секретный код, который был выслан на почту.";
			ОтправитьСообщениеTelegramПоChatID(СтруктураПараметров.ChatID, ТекстСообщения);
			Возврат;
			
		Иначе
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	ИсторияРегистрацииTelegramСрезПоследних.Пользователь,
			|	ИсторияРегистрацииTelegramСрезПоследних.Параметр КАК Пароль
			|ИЗ
			|	РегистрСведений.ИсторияРегистрацииTelegram.СрезПоследних(
			|			,
			|			chat_id = &chat_id
			|				И СобытиеРегистрации = &СобытиеРегистрации) КАК ИсторияРегистрацииTelegramСрезПоследних";
			
			Запрос.УстановитьПараметр("chat_id", СтруктураПараметров.ChatID);
			Запрос.УстановитьПараметр("СобытиеРегистрации", Перечисления.СобытияРегистрацииTelegram.ОтправкаПисьмаСПаролем);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			Выборка = РезультатЗапроса.Выбрать();
			
			Пока Выборка.Следующий() Цикл
				Пароль = Выборка.Пароль;
			КонецЦикла;
			
			Если Пароль = СтруктураПараметров.Параметр Тогда
				
				Запись = РегистрыСведений.ИсторияРегистрацииTelegram.СоздатьМенеджерЗаписи();
				Запись.Период = ТекущаяДата();
				Запись.chat_id = СтруктураПараметров.ChatID;
				Запись.СобытиеРегистрации = Перечисления.СобытияРегистрацииTelegram.ОкончаниеРегистрации;
				Запись.Команда = СтруктураПараметров.Команда;
				Запись.Параметр = СтруктураПараметров.Параметр;
				Запись.Пользователь = Выборка.Пользователь;
				
				Запись.Записать();
				
				ТекстСообщения = "Регистрация завершена успешно. Для начала работы нажмите /start";
				ОтправитьСообщениеTelegramПоChatID(СтруктураПараметров.ChatID, ТекстСообщения);
				
				НаборЗаписей = РегистрыСведений.ПодключенияTelegram.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Пользователь.Установить(Выборка.Пользователь);
				НаборЗаписей.Отбор.chat_id.Установить(СтруктураПараметров.ChatID);
				НаборЗаписей.Прочитать();
				НаборЗаписей.Очистить();
				
				Запись = НаборЗаписей.Добавить();
				Запись.Пользователь = Выборка.Пользователь;
				Запись.chat_id = СтруктураПараметров.ChatID;
				Запись.Актуальность = Истина;
				Запись.АутентификацияПройдена = Истина;
				
				НаборЗаписей.Записать();
				
				Возврат;
				
			Иначе
				
				Запись = РегистрыСведений.ИсторияРегистрацииTelegram.СоздатьМенеджерЗаписи();
				Запись.Период = ТекущаяДата();
				Запись.chat_id = СтруктураПараметров.ChatID;
				Запись.СобытиеРегистрации = Перечисления.СобытияРегистрацииTelegram.НеверныйПароль;
				Запись.Команда = СтруктураПараметров.Команда;
				Запись.Параметр = СтруктураПараметров.Параметр;
				Запись.Пользователь = Справочники.Пользователи.ПустаяСсылка();
				
				Запись.Записать();
				
				ТекстСообщения = "Указан неверный секретный код.";
				ОтправитьСообщениеTelegramПоChatID(СтруктураПараметров.ChatID, ТекстСообщения);
				Возврат;
				
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

