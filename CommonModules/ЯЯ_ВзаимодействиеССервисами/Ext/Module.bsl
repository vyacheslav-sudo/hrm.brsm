Процедура ShowList(Пользователь, Параметр)
	
	ОсновнойМассив = Новый Массив;
	МассивКнопок = Новый Массив();
	
	СписокНедоступныхГрупп = Новый СписокЗначений;
	СписокНедоступныхГрупп.Добавить(Справочники.ГруппыКомандTelegram.ОбщаяГруппа);
	
	Ид = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ГруппыКоманд.ГруппаКоманд,
	|	ГруппыКоманд.ВыполняемоеДействие,
	|	ГруппыКоманд.Параметр
	|ИЗ
	|	(ВЫБРАТЬ
	|		ПРЕДСТАВЛЕНИЕССЫЛКИ(ГруппыКомандTelegramКоманды.Ссылка) КАК ГруппаКоманд,
	|		ГруппыКомандTelegramКоманды.Ссылка.Команда.ВыполняемоеДействие КАК ВыполняемоеДействие,
	|		ГруппыКомандTelegramКоманды.Ссылка.Команда.Параметр КАК Параметр,
	|		ГруппыКомандTelegramКоманды.Ссылка.Порядок КАК Порядок
	|	ИЗ
	|		Справочник.ГруппыКомандTelegram.Команды КАК ГруппыКомандTelegramКоманды
	|	ГДЕ
	|		ГруппыКомандTelegramКоманды.Команда В
	|				(ВЫБРАТЬ
	|					РолиTelegramКоманды.Команда
	|				ИЗ
	|					Справочник.РолиTelegram.Команды КАК РолиTelegramКоманды
	|				ГДЕ
	|					РолиTelegramКоманды.Ссылка В
	|						(ВЫБРАТЬ
	|							ПользователиРолиTelegram.Роль
	|						ИЗ
	|							Справочник.Пользователи.РолиTelegram КАК ПользователиРолиTelegram
	|						ГДЕ
	|							ПользователиРолиTelegram.Ссылка = &Пользователь)
	|					И РолиTelegramКоманды.Команда.Выводить
	|				СГРУППИРОВАТЬ ПО
	|					РолиTelegramКоманды.Команда)
	|		И НЕ ГруппыКомандTelegramКоманды.Ссылка В (&СписокНедоступныхГрупп)
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ГруппыКомандTelegramКоманды.Ссылка.Команда.ВыполняемоеДействие,
	|		ГруппыКомандTelegramКоманды.Ссылка.Команда.Параметр,
	|		ГруппыКомандTelegramКоманды.Ссылка.Порядок,
	|		ПРЕДСТАВЛЕНИЕССЫЛКИ(ГруппыКомандTelegramКоманды.Ссылка)) КАК ГруппыКоманд
	|
	|УПОРЯДОЧИТЬ ПО
	|	ГруппыКоманд.Порядок";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.УстановитьПараметр("СписокНедоступныхГрупп", СписокНедоступныхГрупп);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Ид = Ид + 1;
		Если Ид > 3 Тогда
			ОсновнойМассив.Добавить(МассивКнопок);
			МассивКнопок = Новый Массив;
			Ид = 1;
		КонецЕсли;
		
		МассивКнопок.Добавить(Новый Структура("text, callback_data", Выборка.ГруппаКоманд, СокрЛП(Выборка.ВыполняемоеДействие + " " + Выборка.Параметр)));
		
	КонецЦикла;
	
	ОсновнойМассив.Добавить(МассивКнопок);
	Клавиатура = ПолучитьКлавиатуру(ОсновнойМассив);
	
	ТекстСообщения = "Выберете действие:";
	ОтправитьСообщениеTelegram(Пользователь, ТекстСообщения,,,,Клавиатура);
	
КонецПроцедуры

