
Функция ПолучитьОтвет(ПараметрыЗапроса) Экспорт
	
	СтруктураОтвета = Новый Структура;
	СтруктураОтвета.Вставить("СтрокаHTML", "");
	СтруктураОтвета.Вставить("НаличиеОшибок", Ложь);
	СтруктураОтвета.Вставить("ТекстОшибки", "");
	
	// Проверить параметры запроса
	ТипЗапроса = ПараметрыЗапроса.ТипЗапроса;
	
	Параметры = ПолучитьПараметры();
	
	Токен = Параметры.Токен;
	Сервер = Параметры.Сервер;
	
	ПараметрыРесурса = Новый Структура;
	ПараметрыРесурса.Вставить("ТипЗапроса", ТипЗапроса);
	ПараметрыРесурса.Вставить("Токен", Токен);
	
	Ресурс = ПолучитьРесурс(ПараметрыРесурса, ПараметрыЗапроса);
	
	Если Не ЗначениеЗаполнено(Ресурс) Тогда
		
		ТекстОшибки = "Не найден метод " + ПараметрыЗапроса.ТипЗапроса;
		
		СтруктураОтвета.Вставить("НаличиеОшибок", Истина);
		СтруктураОтвета.Вставить("ТекстОшибки", ТекстОшибки);
		
		Возврат СтруктураОтвета;
		
	КонецЕсли;
	
	Соединение = Новый HTTPСоединение(Сервер, 443 , , , , , Новый ЗащищенноеСоединениеOpenSSL());
	Запрос = Новый HTTPЗапрос(Ресурс);
	
	Результат = Соединение.Получить(Запрос);
	
	Если Результат.КодСостояния = 200 Тогда
		
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(Результат.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8));
		МассивДанных = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		
		Возврат ПолучитьСтруктуруОтвета(ПараметрыЗапроса, МассивДанных, СтруктураОтвета);
		
	ИначеЕсли Результат.КодСостояния = 403 Тогда
		
		ТекстОшибки = "Неправильный токен доступа. Код состояния: 403";
		
		СтруктураОтвета.Вставить("НаличиеОшибок", Истина);
		СтруктураОтвета.Вставить("ТекстОшибки", ТекстОшибки);
		
		Возврат СтруктураОтвета;
		
	ИначеЕсли Результат.КодСостояния = 404 Тогда
		
		ТекстОшибки = "Сервис не найден. Код состояния: 404";
		
		СтруктураОтвета.Вставить("НаличиеОшибок", Истина);
		СтруктураОтвета.Вставить("ТекстОшибки", ТекстОшибки);
		
		Возврат СтруктураОтвета;
		
	ИначеЕсли Результат.КодСостояния = 503 Тогда
		
		ТекстОшибки = "Сервис не доступен. Код состояния: 503";
		
		СтруктураОтвета.Вставить("НаличиеОшибок", Истина);
		СтруктураОтвета.Вставить("ТекстОшибки", ТекстОшибки);
		
		Возврат СтруктураОтвета;
		
	Иначе
		
		ТекстОшибки = "Возникла ошибка. Код состояния: " + Результат.КодСостояния;
		
		СтруктураОтвета.Вставить("НаличиеОшибок", Истина);
		СтруктураОтвета.Вставить("ТекстОшибки", ТекстОшибки);
		
		Возврат СтруктураОтвета;
		
	КонецЕсли;
	
КонецФункции

Функция ПолучитьРесурс(ПараметрыРесурса, ПараметрыЗапроса)
	
	Ресурс = "";
	
	Если ПараметрыРесурса.ТипЗапроса = "fop" Тогда
		Если ПараметрыЗапроса.Свойство("code") Тогда
			Ресурс = "/api/v2/fop/" + ПараметрыЗапроса.code + "?apiKey=" + ПараметрыРесурса.Токен;
		КонецЕсли;
	ИначеЕсли ПараметрыРесурса.ТипЗапроса = "" Тогда
		Ресурс = "";
	ИначеЕсли ПараметрыРесурса.ТипЗапроса = "statistics" Тогда
		Ресурс = "/api/v2/statistics" + "?apiKey=" + ПараметрыРесурса.Токен;
	ИначеЕсли ПараметрыРесурса.ТипЗапроса = "company" Тогда
		Если ПараметрыЗапроса.Свойство("code") Тогда
			Ресурс = "/api/v2/company/" + ПараметрыЗапроса.code + "?apiKey=" + ПараметрыРесурса.Токен;
		КонецЕсли;
	ИначеЕсли ПараметрыРесурса.ТипЗапроса = "" Тогда
		Ресурс = "";
	КонецЕсли;
	
	Возврат Ресурс;
	
КонецФункции

