// Позволяет переопределить ограничение, указанное в модуле менеджера объекта метаданных.
//
// Параметры:
//  Список - ОбъектМетаданных - список, для которого нужно вернуть текст ограничения.
//                              В процедуре ПриЗаполненииСписковСОграничениемДоступа нужно
//                              указать для списка значение Ложь, иначе вызова не будет.
//
//  Ограничение - Структура - со свойствами, как для процедур в модулях менеджеров. См. свойства
//                            в комментарии к процедуре ПриЗаполненииСписковСОграничениемДоступа.
//
Процедура ПриЗаполненииОграниченияДоступа(Список, Ограничение) Экспорт
	
	//++ Локализация
	//++ НЕ УТ
	ЗарплатаКадры.ПриЗаполненииОграниченияДоступа(Список, Ограничение);
	Если Список = Метаданные.Справочники.ФизическиеЛица Тогда
		Ограничение.Текст =
		"РазрешитьЧтениеИзменение
		|ГДЕ
		|	ЭтоГруппа
		|	ИЛИ ЗначениеРазрешено(Ссылка)";
	КонецЕсли;
	//-- НЕ УТ
	//-- Локализация
	
КонецПроцедуры

// Заполняет виды доступа, используемые в ограничениях прав доступа.
// Примечание: виды доступа Пользователи и ВнешниеПользователи предопределены,
// но их можно удалить из списка ВидыДоступа, если они не требуются для ограничения прав доступа.
//
// см. УправлениеДоступомПереопределяемый.ЗаполнитьВидыДоступа()
//
Процедура ЗаполнитьВидыДоступа(ВидыДоступа) Экспорт
	
	//++ Локализация

	//++ НЕ УТ
	ЗарплатаКадры.УправлениеДоступомЗаполнитьСвойстваВидаДоступа(ВидыДоступа);
	
	// локальное исправление 00-00170163, 30163804
	ГруппыФизическихЛицНайдены = Ложь;
	МассивУдаляемыхВидов = Новый Массив;
	Для Каждого Строка Из ВидыДоступа Цикл
		Если Строка.Имя = "ГруппыФизическихЛиц" И Не ГруппыФизическихЛицНайдены Тогда
			ГруппыФизическихЛицНайдены = Истина;
		ИначеЕсли Строка.Имя = "ГруппыФизическихЛиц" И ГруппыФизическихЛицНайдены Тогда
			МассивУдаляемыхВидов.Добавить(Строка);
		ИначеЕсли Строка.Имя = "СтруктураПредприятия" Тогда
			МассивУдаляемыхВидов.Добавить(Строка);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого Строка Из МассивУдаляемыхВидов Цикл
		ВидыДоступа.Удалить(Строка);
	КонецЦикла;
	
	//-- НЕ УТ
	
	//-- Локализация
	
КонецПроцедуры

