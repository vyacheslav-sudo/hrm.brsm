Процедура ПроверитьОтветственныхЛицОрганизации(строка)
	Если Число(Строка.ОтветственныеЛица_ОтветственноеЛицоПорядок)>3 Тогда
		//перечисление "ОтветственныеЛицаОрганизаций" синхронны только первые 4 элемента
		Возврат;
	КонецЕсли;
	Организация = Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор(строка.УИД_Организация));
	Если Не ЗначениеЗаполнено(строка.УИД_ОтветственныеЛица_Должность) Тогда
		Должность = Справочники.Должности.ПустаяСсылка();
	Иначе		
		Должность = Справочники.Должности.ПолучитьСсылку(Новый УникальныйИдентификатор(строка.УИД_ОтветственныеЛица_Должность));
	КонецЕсли;
	ОтветственноеЛицо = Перечисления.ОтветственныеЛицаОрганизаций.Получить(Строка.ОтветственныеЛица_ОтветственноеЛицоПорядок);
	Если Не ЗначениеЗаполнено(строка.УИД_ОтветственныеЛица_ФизическоеЛицо) Тогда
		//означает что очистили, поставить предыдущему дату окончания
		Запрос = Новый Запрос("ВЫБРАТЬ
		                      |	ОтветственныеЛицаОрганизаций.Ссылка КАК Ссылка
		                      |ИЗ
		                      |	Справочник.ОтветственныеЛицаОрганизаций КАК ОтветственныеЛицаОрганизаций
		                      |ГДЕ
		                      |	ОтветственныеЛицаОрганизаций.ОтветственноеЛицо = &ОтветственноеЛицо
		                      |	И ОтветственныеЛицаОрганизаций.ДолжностьСсылка = &ДолжностьСсылка
		                      |	И ОтветственныеЛицаОрганизаций.Владелец = &Владелец
		                      |	И ОтветственныеЛицаОрганизаций.ДатаОкончания = &ДатаОкончания");
		Запрос.УстановитьПараметр("ОтветственноеЛицо", ОтветственноеЛицо);
		Запрос.УстановитьПараметр("Владелец", Организация);
		Запрос.УстановитьПараметр("ДолжностьСсылка", Должность);
		Запрос.УстановитьПараметр("ДатаОкончания", Дата('00010101'));
		Рез = Запрос.Выполнить().Выгрузить();
		Если Рез.Количество() = 1 Тогда
			ОбъектОтветственныхЛиц = Рез[0].Ссылка.ПолучитьОбъект();
			ОбъектОтветственныхЛиц.ДатаОкончания = ДатаJsonВЗнач(Строка.ОтветственныеЛица_Период);
			ОбъектОтветственныхЛиц.Записать();
		КонецЕсли;
		Возврат;
	КонецЕсли;
	ФизЛицо = Справочники.ФизическиеЛица.ПолучитьСсылку(Новый УникальныйИдентификатор(строка.УИД_ОтветственныеЛица_ФизическоеЛицо));
	ДатаНачала = ДатаJsonВЗнач(Строка.ОтветственныеЛица_Период);
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ОтветственныеЛицаОрганизаций.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ОтветственныеЛицаОрганизаций КАК ОтветственныеЛицаОрганизаций
	|ГДЕ
	|	ОтветственныеЛицаОрганизаций.ОтветственноеЛицо = &ОтветственноеЛицо
	|	И ОтветственныеЛицаОрганизаций.ФизическоеЛицо = &ФизическоеЛицо
	|	И ОтветственныеЛицаОрганизаций.ДолжностьСсылка = &ДолжностьСсылка
	|	И ОтветственныеЛицаОрганизаций.ДатаНачала = &ДатаНачала
	|	И ОтветственныеЛицаОрганизаций.Владелец = &Владелец");
	Запрос.УстановитьПараметр("ОтветственноеЛицо", ОтветственноеЛицо);
	Запрос.УстановитьПараметр("Владелец", Организация);
	Запрос.УстановитьПараметр("ФизическоеЛицо", ФизЛицо);
	Запрос.УстановитьПараметр("ДолжностьСсылка", Должность);
	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	Рез = Запрос.Выполнить().Выгрузить();
	Если Рез.Количество() = 0 Тогда // не знайшли - створюємо
		НовОтвЛицоОрг = Справочники.ОтветственныеЛицаОрганизаций.СоздатьЭлемент();
		НовОтвЛицоОрг.Владелец = Организация;
		
		ОбъектФизЛицо = ФизЛицо.ПолучитьОбъект();
		Если ОбъектФизЛицо = Неопределено Тогда
			СоздатьФизЛицо(строка, ФизЛицо, "ОтветственныеЛица_ФизическоеЛицо_");
		Иначе
			ЗаполнитьФизЛицо(строка, ОбъектФизЛицо, "ОтветственныеЛица_ФизическоеЛицо_");
		КонецЕсли;  
		
		НовОтвЛицоОрг.ФизическоеЛицо = ФизЛицо;  

		Если ЗначениеЗаполнено(Должность) Тогда
			ОбъектДолжность = Должность.ПолучитьОбъект();
			Если ОбъектДолжность = Неопределено Тогда
				СоздатьДолжность(строка,Должность,"ОтветственныеЛица_Должность_");
			Иначе
				ЗаполнитьДолжность(строка,ОбъектДолжность,"ОтветственныеЛица_Должность_");
			КонецЕсли;   
		КонецЕсли;
		НовОтвЛицоОрг.ДолжностьСсылка = Должность;
		НовОтвЛицоОрг.Должность = Должность.Наименование;
		НовОтвЛицоОрг.ОтветственноеЛицо = ОтветственноеЛицо;
		НовОтвЛицоОрг.ДатаНачала = ДатаНачала;
		НовОтвЛицоОрг.Наименование = ФизическиеЛицаУТ.ФамилияИнициалыФизЛица(НовОтвЛицоОрг.ФизическоеЛицо, НовОтвЛицоОрг.ДатаНачала);

		НовОтвЛицоОрг.Записать();
		//Найти предыдущий и поставить дату окончания
		ЗапросПредыдущий = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1
		                                |	ОтветственныеЛицаОрганизаций.Ссылка КАК Ссылка
		                                |ИЗ
		                                |	Справочник.ОтветственныеЛицаОрганизаций КАК ОтветственныеЛицаОрганизаций
		                                |ГДЕ
		                                |	ОтветственныеЛицаОрганизаций.ОтветственноеЛицо = &ОтветственноеЛицо
		                                |	И ОтветственныеЛицаОрганизаций.ДатаНачала < &ДатаНачала
		                                |	И ОтветственныеЛицаОрганизаций.Владелец = &Владелец
		                                |
		                                |УПОРЯДОЧИТЬ ПО
		                                |	ОтветственныеЛицаОрганизаций.ДатаНачала УБЫВ");
		ЗапросПредыдущий.УстановитьПараметр("ОтветственноеЛицо", ОтветственноеЛицо);
		ЗапросПредыдущий.УстановитьПараметр("Владелец", Организация);
		ЗапросПредыдущий.УстановитьПараметр("ДатаНачала", ДатаНачала);
		РезПредыдущий = ЗапросПредыдущий.Выполнить().Выгрузить();
		Если РезПредыдущий.Количество() = 1 Тогда
			ПредыдущийОбъект = РезПредыдущий[0].Ссылка.ПолучитьОбъект();
			ПредыдущийОбъект.ДатаОкончания = НачалоДня(ДатаНачала)-1;
			ПредыдущийОбъект.Записать();
		КонецЕсли;  
	ИначеЕсли Рез.Количество() = 1 Тогда
		ОбъектОтвЛицоОрг = Рез[0].Ссылка.ПолучитьОбъект();
		ОбъектОтвЛицоОрг.Владелец = Организация;
		
		ОбъектФизЛицо = ФизЛицо.ПолучитьОбъект();
		Если ОбъектФизЛицо = Неопределено Тогда
			СоздатьФизЛицо(строка, ФизЛицо, "ОтветственныеЛица_ФизическоеЛицо_");
		Иначе
			ЗаполнитьФизЛицо(строка, ОбъектФизЛицо, "ОтветственныеЛица_ФизическоеЛицо_");
		КонецЕсли;  
		
		ОбъектОтвЛицоОрг.ФизическоеЛицо = ФизЛицо;  

		Если ЗначениеЗаполнено(Должность) Тогда
			ОбъектДолжность = Должность.ПолучитьОбъект();
			Если ОбъектДолжность = Неопределено Тогда
				СоздатьДолжность(строка,Должность,"ОтветственныеЛица_Должность_");
			Иначе
				ЗаполнитьДолжность(строка,ОбъектДолжность,"ОтветственныеЛица_Должность_");
			КонецЕсли;   
		КонецЕсли;
		ОбъектОтвЛицоОрг.ДолжностьСсылка = Должность;
		ОбъектОтвЛицоОрг.Должность = Должность.Наименование;
		ОбъектОтвЛицоОрг.ОтветственноеЛицо = ОтветственноеЛицо;
		ОбъектОтвЛицоОрг.ДатаНачала = ДатаНачала;
		ОбъектОтвЛицоОрг.Наименование = ФизическиеЛицаУТ.ФамилияИнициалыФизЛица(ОбъектОтвЛицоОрг.ФизическоеЛицо, ОбъектОтвЛицоОрг.ДатаНачала);

		ОбъектОтвЛицоОрг.Записать();
		//Найти предыдущий и поставить дату окончания
		ЗапросПредыдущий = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1
		                                |	ОтветственныеЛицаОрганизаций.Ссылка КАК Ссылка
		                                |ИЗ
		                                |	Справочник.ОтветственныеЛицаОрганизаций КАК ОтветственныеЛицаОрганизаций
		                                |ГДЕ
		                                |	ОтветственныеЛицаОрганизаций.ОтветственноеЛицо = &ОтветственноеЛицо
		                                |	И ОтветственныеЛицаОрганизаций.ДатаНачала < &ДатаНачала
		                                |	И ОтветственныеЛицаОрганизаций.Владелец = &Владелец
		                                |
		                                |УПОРЯДОЧИТЬ ПО
		                                |	ОтветственныеЛицаОрганизаций.ДатаНачала УБЫВ");
		ЗапросПредыдущий.УстановитьПараметр("ОтветственноеЛицо", ОтветственноеЛицо);
		ЗапросПредыдущий.УстановитьПараметр("Владелец", Организация);
		ЗапросПредыдущий.УстановитьПараметр("ДатаНачала", ДатаНачала);
		РезПредыдущий = ЗапросПредыдущий.Выполнить().Выгрузить();
		Если РезПредыдущий.Количество() = 1 Тогда
			ПредыдущийОбъект = РезПредыдущий[0].Ссылка.ПолучитьОбъект();
			ПредыдущийОбъект.ДатаОкончания = НачалоДня(ДатаНачала)-1;
			ПредыдущийОбъект.Записать();
		КонецЕсли;  
	КонецЕсли;
КонецПроцедуры

Процедура СоздатьЗаполнитьДокументПриема(строка, ДокПриема)
	СтруктураРеквизитов = ПоличитьРеквизитыИзСтруктуры(строка, "ДокПриема_");
	ЗаполнитьЗначенияСвойств(ДокПриема,СтруктураРеквизитов);
	ДокПриема.Организация = Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор(строка.УИД_Организация));
	ДокПриема.Ответственный = Справочники.Пользователи.ПолучитьСсылку(Новый УникальныйИдентификатор(строка.УИД_Ответственный));
	ДокПриема.НачисленияУтверждены = Истина;
	//СтруктураРеквизитовТаблицы = ПоличитьРеквизитыИзСтруктуры(строка, "ДокПриемаРаботники_");
	//НовСтрокаСотрудник = ДокПриема.Сотрудники.Добавить(); змінили документ приймач
	//ЗаполнитьЗначенияСвойств(НовСтрокаСотрудник,СтруктураРеквизитовТаблицы);
	ДокПриема.Сотрудник = Справочники.Сотрудники.ПолучитьСсылку(Новый УникальныйИдентификатор(строка.УИД_Сотрудник));
	ДокПриема.ФизическоеЛицо = Справочники.ФизическиеЛица.ПолучитьСсылку(Новый УникальныйИдентификатор(строка.УИД_ФизЛицо));
	ДокПриема.Должность = Справочники.Должности.ПолучитьСсылку(Новый УникальныйИдентификатор(строка.УИД_Должность));
	ДокПриема.Подразделение = Справочники.ПодразделенияОрганизаций.ПолучитьСсылку(Новый УникальныйИдентификатор(строка.УИД_ПодразделениеОрганизации));
	ДокПриема.ГрафикРаботы = Справочники.ГрафикиРаботыСотрудников.ПолучитьСсылку(Новый УникальныйИдентификатор(строка.УИД_ГрафикРаботы));
