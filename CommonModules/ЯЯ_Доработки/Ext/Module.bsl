	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку(Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто,"",Истина));
	
	ЗаписатьJSON(ЗаписьJSON, СтруктураОтвета);
	
	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции       

Функция СформироватьОтветВJson(СтрокаОтвет, НаличиеФайла=Ложь)
	
	Если НаличиеФайла Тогда
		СтрокаОтвет = СтрЗаменить(СтрокаОтвет, "\r\n", "");
	КонецЕсли;
	
	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.УстановитьТелоИзСтроки(СтрокаОтвет, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	
	Возврат Ответ;
	
КонецФункции

Процедура ОтправитьТаблицу(ТаблицаУспешноОбработаных)
	МассивДляПередачи = ОбщегоНазначения.ТаблицаЗначенийВМассив(ТаблицаУспешноОбработаных);
	Запись = СериализироватьСтруктураВСтроку(МассивДляПередачи);
	РезультатОтправки = ОтправитьHTTPОтвет(ЯЯ_Доработки.ПолучитьПредопределенныйОбъект("HTTPСервисОбменаHRMОтправитьУспешные"), Запись);
	Если РезультатОтправки.КодСостояния = 200 Тогда
	КонецЕсли;
КонецПроцедуры

