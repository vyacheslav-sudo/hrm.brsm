Процедура СоздатьЗаполнитьСотрудника(строка, Сотрудник)
	СтруктураРеквизитов = ПоличитьРеквизитыИзСтруктуры(строка, "Сотрудник_");
	ЗаполнитьЗначенияСвойств(Сотрудник,СтруктураРеквизитов);
	Сотрудник.ФизическоеЛицо = Справочники.ФизическиеЛица.ПолучитьСсылку(Новый УникальныйИдентификатор(Строка.УИД_Сотрудник_ФизЛицо));
	Сотрудник.ГоловнаяОрганизация = Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор(Строка.УИД_Организация));
	Сотрудник.ГоловнойСотрудник = Справочники.Сотрудники.ПолучитьСсылку(Новый УникальныйИдентификатор(строка.УИД_Сотрудник));
	Сотрудник.Записать();
КонецПроцедуры

Процедура СоздатьСотрудника(строка, Сотрудник)
	НовСотрудник = Справочники.Сотрудники.СоздатьЭлемент();
	НовСотрудник.УстановитьСсылкуНового(Сотрудник);
	СоздатьЗаполнитьСотрудника(строка, НовСотрудник);
КонецПроцедуры

Процедура ЗаполнитьСотрудника(строка, Сотрудник)
	СоздатьЗаполнитьСотрудника(строка, Сотрудник);
КонецПроцедуры

Процедура СоздатьЗаполнитьДолжность(строка, Должность, ЗаголовокСтруктуры)
	СтруктураРеквизитов = ПоличитьРеквизитыИзСтруктуры(строка, ЗаголовокСтруктуры);
	ЗаполнитьЗначенияСвойств(Должность,СтруктураРеквизитов);
	//Виключення довідкник з напередвизначених елементів - шукаємо по найменуванню
	Должность.Категория = Справочники.КатегорииДолжностей.НайтиПоНаименованию(СтруктураРеквизитов.Категория_Наименование);
	
	//треба розібратися
	Если Не Должность.ПометкаУдаления Тогда
		Должность.ВведенаВШтатноеРасписание = Истина;
		Должность.ДатаВвода = НачалоГода(ТекущаяДата());
	Иначе
		Должность.ВведенаВШтатноеРасписание = Ложь;
		Должность.ИсключенаИзШтатногоРасписания = Истина;
	КонецЕсли;
	//
	Должность.Записать();
КонецПроцедуры

Процедура СоздатьДолжность(строка, Должность,ЗаголовокСтруктуры) 
	НовДолжность = Справочники.Должности.СоздатьЭлемент();
	НовДолжность.УстановитьСсылкуНового(Должность);
	СоздатьЗаполнитьДолжность(строка, НовДолжность,ЗаголовокСтруктуры);
КонецПроцедуры

Процедура ЗаполнитьДолжность(строка, Должность,ЗаголовокСтруктуры)
	СоздатьЗаполнитьДолжность(строка, Должность,ЗаголовокСтруктуры);
КонецПроцедуры  

Процедура СоздатьЗаполнитьПодразделениеОрганизаций(строка, ПодразделениеОрганизаций)
	СтруктураРеквизитов = ПоличитьРеквизитыИзСтруктуры(строка, "ПодразделениеОрганизации_");
	ЗаполнитьЗначенияСвойств(ПодразделениеОрганизаций,СтруктураРеквизитов);
	//створити ієрархію спочатку верхній рівень
	Если СтрДлина(СтруктураРеквизитов["РодительРодитель"]) Тогда
		РодительРодитель = Справочники.ПодразделенияОрганизаций.ПолучитьСсылку(Новый УникальныйИдентификатор(СтруктураРеквизитов["УИД_РодительРодитель"]));
		Если РодительРодитель.ПолучитьОбъект() = Неопределено Тогда
			//создать новый
			НовРодительРодитель = Справочники.ПодразделенияОрганизаций.СоздатьЭлемент();
			НовРодительРодитель.УстановитьСсылкуНового(РодительРодитель);
			НовРодительРодитель.Код = СтруктураРеквизитов["РодительРодительКод"];
			НовРодительРодитель.Наименование = СтруктураРеквизитов["РодительРодитель"];
			НовРодительРодитель.ПометкаУдаления = СтруктураРеквизитов["РодительРодитель_ПометкаУдаления"];
			НовРодительРодитель.Владелец = Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор(строка["УИД_ПодразделениеОрганизации_РодительРодительВладелец"]));
			
			//треба розібратися
			Если Не НовРодительРодитель.ПометкаУдаления Тогда
				НовРодительРодитель.Сформировано = Истина;
				НовРодительРодитель.ДатаСоздания = НачалоГода(ТекущаяДата()); 
			Иначе
				НовРодительРодитель.Расформировано = Истина;
			КонецЕсли;
			//
			
			НовРодительРодитель.Записать();
		Иначе
			//использовать существующий
		КонецЕсли;
	КонецЕсли;
	//і рівень нижче
	Если СтрДлина(СтруктураРеквизитов["Родитель"]) Тогда
		Родитель = Справочники.ПодразделенияОрганизаций.ПолучитьСсылку(Новый УникальныйИдентификатор(СтруктураРеквизитов["УИД_Родитель"]));
		Если Родитель.ПолучитьОбъект() = Неопределено Тогда
			//создать новый
			НовРодитель = Справочники.ПодразделенияОрганизаций.СоздатьЭлемент();
			НовРодитель.УстановитьСсылкуНового(Родитель);
			НовРодитель.Код = СтруктураРеквизитов["РодительКод"];
			НовРодитель.Наименование = СтруктураРеквизитов["Родитель"];
			НовРодитель.ПометкаУдаления = СтруктураРеквизитов["Родитель_ПометкаУдаления"];
			НовРодитель.Родитель = РодительРодитель;
			НовРодитель.Владелец = Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор(строка["УИД_ПодразделениеОрганизации_РодительВладелец"]));
			
			//треба розібратися
			Если Не НовРодитель.ПометкаУдаления Тогда
				НовРодитель.Сформировано = Истина;
				НовРодитель.ДатаСоздания = НачалоГода(ТекущаяДата()); 
			Иначе
				НовРодитель.Расформировано = Истина;
			КонецЕсли;
			//
			
			НовРодитель.Записать();
		Иначе
			//использовать существующий
		КонецЕсли;
		ПодразделениеОрганизаций.Родитель = Родитель;
	КонецЕсли;
	ПодразделениеОрганизаций.Владелец = Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор(строка["УИД_ПодразделениеОрганизации_Владелец"]));
	//треба розібратися
	Если Не ПодразделениеОрганизаций.ПометкаУдаления Тогда
		ПодразделениеОрганизаций.Сформировано = Истина;
		ПодразделениеОрганизаций.ДатаСоздания = НачалоГода(ТекущаяДата());
	Иначе
		ПодразделениеОрганизаций.Расформировано = Истина;
	КонецЕсли;
	//
	ПодразделениеОрганизаций.Записать();
КонецПроцедуры

