Функция ПолучитьПредопределенныйОбъект(Параметр, Родитель = Неопределено) Экспорт
	
	Если ТипЗнч(Параметр) = Тип("Строка") Тогда
		Наименование = Параметр;
		Ссылка = Справочники.Я_ПредопределенныеОбъекты.НайтиПоНаименованию(Наименование, Истина, Родитель);
	ИначеЕсли ТипЗнч(Параметр) = Тип("СправочникСсылка.Я_ПредопределенныеОбъекты") Тогда
		Наименование = Параметр.Наименование;
		Ссылка = Параметр;
	КонецЕсли;
	
	Если НЕ ЯЯ_Доработки.Выбрано(Ссылка) Тогда
		Сообщить("ВНИМАНИЕ! Не найден предопределенный объект " + Наименование + " - сообщите разработчикам!", СтатусСообщения.Внимание);
	ИначеЕсли НЕ ЯЯ_Доработки.Выбрано(Ссылка.Объект) Тогда
		Сообщить("ВНИМАНИЕ! Не найден предопределенный объект " + Наименование + " - сообщите разработчикам!", СтатусСообщения.Внимание);
	КонецЕсли;
	
	Возврат Ссылка.Объект;
	
КонецФункции

// Функция - аналог использования функции ЗначениеЗаполнено с модификацией
//
// Параметры:
//  Значение			 - Объект проверки
//  ТекстПредупреждения	 - Текст предупреждения для пользователей
//  НомерСтроки			 - Номер строки проверки
//  Отказ				 - Отказ
//  Предупреждать		 - Признак вывода предупреждения или сообщения (Истина вызывает метод Предупредить(); Ложь вызывает метод Сообщить() )
// 
// Возвращаемое значение:
//  Результат - Истина/Ложь
//
Функция Выбрано(Значение, ТекстПредупреждения = Неопределено, НомерСтроки = 0, Отказ = Ложь, Предупреждать = Ложь) Экспорт
	
	Результат = Истина;
	ТипЗначения = ТипЗнч(Значение);
	
	// Сначала примитивные типы
	Если Значение = Неопределено ИЛИ Значение = NULL Тогда
		Результат = Ложь;
	ИначеЕсли ТипЗначения=Тип("Булево") Тогда
		Результат = Истина;
	ИначеЕсли ТипЗначения=Тип("Число") 
		Тогда Если Значение = 0 Тогда 
			Результат = Ложь;
		КонецЕсли;
	ИначеЕсли ТипЗначения=Тип("Строка") Тогда
		Если СокрЛП(Значение)="" Тогда
			Результат = Ложь;
		КонецЕсли;
	ИначеЕсли ТипЗначения=Тип("Дата") Тогда
		Если Значение=Дата('00010101') Тогда
			Результат = Ложь;
		КонецЕсли;
		#Если Клиент Тогда
		ИначеЕсли ТипЗначения = Тип("ПолеВвода") И НЕ Выбрано(Значение.Значение) Тогда
			Результат = Ложь;
		#КонецЕсли
		
		// Для остальных будем считать значение пустым, если оно равно дефолтному значению своего типа
	Иначе
		Попытка
			Если Значение = Новый(ТипЗначения) Тогда
				Результат = Ложь;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Если Результат = Ложь Тогда
		Если ТекстПредупреждения <> Неопределено тогда
			#Если Клиент Тогда
				Если Предупреждать тогда
					ПоказатьПредупреждение(, "Не заполнено поле '" + ТекстПредупреждения + "'" + ?(НомерСтроки=0,""," в строке № " + НомерСтроки) + " !");
				Иначе
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнено поле '"+ТекстПредупреждения+"'"+?(НомерСтроки=0,""," в строке № "+НомерСтроки)+" !", СтатусСообщения.Важное);
				КонецЕсли;
			#КонецЕсли
		КонецЕсли;
		Отказ = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

