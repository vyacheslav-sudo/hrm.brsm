Функция ПолучитьШтатноеРасписание(Строка)
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ШтатноеРасписание.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ШтатноеРасписание КАК ШтатноеРасписание
	|ГДЕ
	|	ШтатноеРасписание.Подразделение = &Подразделение
	|	И ШтатноеРасписание.Должность = &Должность
	|	И ШтатноеРасписание.Владелец = &Организация");
	Подразделение = Справочники.ПодразделенияОрганизаций.ПолучитьСсылку(Новый УникальныйИдентификатор(Строка.УИД_ПодразделениеОрганизации));
	Должность = Справочники.Должности.ПолучитьСсылку(Новый УникальныйИдентификатор(Строка.УИД_Должность));
	Организация = Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор(Строка.УИД_Организация));
	Запрос.УстановитьПараметр("Подразделение",Подразделение);
	Запрос.УстановитьПараметр("Должность",Должность);
	Запрос.УстановитьПараметр("Организация",Организация);
	Рез = Запрос.Выполнить().Выгрузить();
	Если Рез.Количество() = 1 Тогда //штатна одиниця може бути одна
		Возврат Рез[0].Ссылка
	ИначеЕсли Рез.Количество() = 0 Тогда //треба створити нову
		НовШтатРасп = Справочники.ШтатноеРасписание.СоздатьЭлемент();
		НовШтатРасп.Подразделение = Подразделение;
		НовШтатРасп.Должность = Должность;  
		НовШтатРасп.Владелец = Организация;
		//можливо треба допрацювати отримання найменування
		НовШтатРасп.Наименование = УправлениеШтатнымРасписаниемКлиентСервер.НаименованиеПозицииШтатногоРасписания(
		Подразделение,
		Должность);
		// 
		НовШтатРасп.Записать(); 
		Возврат НовШтатРасп.Ссылка;
	КонецЕсли;
КонецФункции

Функция ДатаJsonВЗнач(JsonДата) 
	Если ЗначениеЗаполнено(JsonДата) Тогда
		СтрокаДата = СтрЗаменить(JsonДата, "-", "");
		СтрокаДата = СтрЗаменить(СтрокаДата, ":", "");
		СтрокаДата = СтрЗаменить(СтрокаДата, "T", "");
		Дата = Дата(Лев(СтрокаДата, 14));
	Иначе
		Дата = Дата("00010101");
	КонецЕсли;
	Возврат Дата;
КонецФункции

Функция ПоличитьРеквизитыИзСтруктуры(Строка, ПрефиксРеквизитов)
	СтруктураЗаполнения = Новый Структура;
	Для каждого Элемента из Строка Цикл
		ПоискПрефикса = СтрНайти(Элемента.Ключ, ПрефиксРеквизитов);
		Если ПоискПрефикса>0 Тогда
			СтруктураЗаполнения.Вставить(СтрЗаменить(Элемента.Ключ,ПрефиксРеквизитов,""), Элемента.Значение);
			Если СтрНайти(Элемента.Ключ, "Дата")>0 Тогда  
				СтруктураЗаполнения[СтрЗаменить(Элемента.Ключ,ПрефиксРеквизитов,"")] = ДатаJsonВЗнач(СтруктураЗаполнения[СтрЗаменить(Элемента.Ключ,ПрефиксРеквизитов,"")]);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Возврат СтруктураЗаполнения;
КонецФункции

Процедура ЗаполнитьОбновитьФизЛицо(строка, ФизЛицо, ЗаголовокСтруктуры)
	СтруктураРеквизитов = ПоличитьРеквизитыИзСтруктуры(строка, ЗаголовокСтруктуры);
	ЗаполнитьЗначенияСвойств(ФизЛицо,СтруктураРеквизитов);
	//створити ієрархію спочатку верхній рівень
	Если СтрДлина(СтруктураРеквизитов["РодительРодитель"]) Тогда
		РодительРодитель = Справочники.ФизическиеЛица.ПолучитьСсылку(Новый УникальныйИдентификатор(СтруктураРеквизитов["УИД_РодительРодитель"]));
		Если РодительРодитель.ПолучитьОбъект() = Неопределено Тогда
			//создать новый
			НовРодительРодитель = Справочники.ФизическиеЛица.СоздатьГруппу();
			НовРодительРодитель.УстановитьСсылкуНового(РодительРодитель);
			НовРодительРодитель.Код = СтруктураРеквизитов["РодительРодительКод"];
			НовРодительРодитель.Наименование = СтруктураРеквизитов["РодительРодитель"];
			НовРодительРодитель.Записать();
		Иначе
			//использовать существующий
		КонецЕсли;
	КонецЕсли;
	//і рівень нижче
	Если СтрДлина(СтруктураРеквизитов["Родитель"]) Тогда
		Родитель = Справочники.ФизическиеЛица.ПолучитьСсылку(Новый УникальныйИдентификатор(СтруктураРеквизитов["УИД_Родитель"]));
		Если Родитель.ПолучитьОбъект() = Неопределено Тогда
			//создать новый
			НовРодитель = Справочники.ФизическиеЛица.СоздатьГруппу();
			НовРодитель.УстановитьСсылкуНового(Родитель);
			НовРодитель.Код = СтруктураРеквизитов["РодительКод"];
			НовРодитель.Наименование = СтруктураРеквизитов["Родитель"];
			НовРодитель.Родитель = РодительРодитель;
			НовРодитель.Записать();
		Иначе
			//использовать существующий
		КонецЕсли;
		ФизЛицо.Родитель = Родитель;
	КонецЕсли;
	ФизЛицо.ФИО = СтруктураРеквизитов.Наименование;
	ФизЛицо.Пол = Перечисления.ПолФизическогоЛица[СтруктураРеквизитов.Пол];
	ФизЛицо.Записать();
	//Заполнить регистр сведений ФИО
	ФИОФизическиеЛица = РегистрыСведений.ФИОФизическихЛиц.СоздатьМенеджерЗаписи();
	ФИОФизическиеЛица.ФизическоеЛицо = ФизЛицо.Ссылка;
	ФИОФизическиеЛица.Фамилия = ФизЛицо.Фамилия;
	ФИОФизическиеЛица.Имя = ФизЛицо.Имя;
	ФИОФизическиеЛица.Отчество = ФизЛицо.Отчество;
	ФИОФизическиеЛица.Период = ?(ЗначениеЗаполнено(ФизЛицо.ДатаРождения), ФизЛицо.ДатаРождения, ЗарплатаКадрыКлиентСервер.ДатаОтсчетаПериодическихСведений());
	ФИОФизическиеЛица.Записать();
КонецПроцедуры 

