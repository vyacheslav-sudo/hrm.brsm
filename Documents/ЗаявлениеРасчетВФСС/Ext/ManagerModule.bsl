				ОбластьСтрока.Параметры.Серия = "Х";
				ОбластьСтрока.Параметры.Номер = СокрЛП(ЗапросПоТЧ.ТЧ1.НомерБольничного);
			Иначе	
				СерияНомер = УчетПособийСоциальногоСтрахования.РазложитьНомерБольничного(ЗапросПоТЧ.ТЧ1.НомерБольничного);
				ОбластьСтрока.Параметры.Серия = СерияНомер.Серия;
				ОбластьСтрока.Параметры.Номер = СерияНомер.Номер;
