&НаКлиенте
Процедура ДобавитьПоказательВОтчетЗвит1С(Отчет, ИмяТаблицыЗвит1С = "", ИмяЗвит1С, Значение, ЗаписыватьПустое = Ложь)
	
	Если НЕ ЗаписыватьПустое И НЕ ЗначениеЗаполнено(Значение) Тогда
		Возврат;	
	КонецЕсли;
	
	Попытка
		Отчет.SetValue(ИмяТаблицыЗвит1С, ИмяЗвит1С, Значение); 
	Исключение
		Если глМенеджерЗвит1С.ФлагОтладки Тогда
			СтрИмяТаб = ?(ПустаяСтрока(ИмяТаблицыЗвит1С),"",НСтр("ru='"", имя таблицы ""';uk='"", им'я таблиці ""'")+ИмяТаблицыЗвит1С);
			Сообщить(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='FREDO Звіт. Ошибка установки показателя (схема ""  %1 "" %2  "", поле "" %3 "", тип значения "" %4 "", значение "" %5"")';uk='FREDO Звіт. Помилка установки показника (схема ""  %1 "" %2  "", поле "" %3 "", тип значення "" %4 "", значення "" %5"")'"), Отчет.CharCode, СтрИмяТаб,ИмяЗвит1С,ТипЗнч(Значение),Значение), СтатусСообщения.Внимание);
		КонецЕсли;
	КонецПопытки;
		
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьСтрокуВОтчетЗвит1С(Отчет, ИмяТаблицыЗвит1С)

	Отчет.NewRow(ИмяТаблицыЗвит1С);

