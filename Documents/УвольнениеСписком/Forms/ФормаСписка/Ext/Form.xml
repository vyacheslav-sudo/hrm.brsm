	ДокументУвольнениеСписком.Организация,
	ДокументУвольнениеСписком.Начислено,
	ДокументУвольнениеСписком.Удержано,
	ДокументУвольнениеСписком.ПорядокВыплаты,
	ДокументУвольнениеСписком.ПланируемаяДатаВыплаты,
	ДокументУвольнениеСписком.ИсправленныйДокумент,
	ДокументУвольнениеСписком.ДокументРассчитан,
	ДокументУвольнениеСписком.Рассчитал,
	ДокументУвольнениеСписком.ПредставлениеПериода,
	ДокументУвольнениеСписком.Руководитель,
	ДокументУвольнениеСписком.ДолжностьРуководителя,
	ДокументУвольнениеСписком.ГлавныйБухгалтер,
	ДокументУвольнениеСписком.Бухгалтер,
	ДокументУвольнениеСписком.РаботникКадровойСлужбы,
	ДокументУвольнениеСписком.ДолжностьРаботникаКадровойСлужбы,
	ДокументУвольнениеСписком.Исполнитель,
	ДокументУвольнениеСписком.ДолжностьИсполнителя,
	ДокументУвольнениеСписком.ВидДоговора,
	ДокументУвольнениеСписком.Ответственный,
	ДокументУвольнениеСписком.Комментарий,
	ДокументУвольнениеСписком.МоментВремени,
	ВЫБОР
		КОГДА ДокументУвольнениеСписком.ДокументРассчитан = ЛОЖЬ
				И ДокументУвольнениеСписком.ПометкаУдаления = ЛОЖЬ
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ТребуетОбработки,
	ДокументУвольнениеСписком.КраткийСоставДокумента,
	ВЫБОР
		КОГДА НаличиеПрисоединенныхФайлов.ЕстьФайлы ЕСТЬ NULL ТОГДА
			0
		КОГДА НаличиеПрисоединенныхФайлов.ЕстьФайлы ТОГДА
			1
		ИНАЧЕ
			0
	КОНЕЦ КАК ЕстьФайлы
ИЗ
	Документ.УвольнениеСписком КАК ДокументУвольнениеСписком
	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеПрисоединенныхФайлов
		ПО ДокументУвольнениеСписком.Ссылка = НаличиеПрисоединенныхФайлов.ОбъектСФайлами
</QueryText>
